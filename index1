            const data = db[key]; if (!data) return '<p class="text-sm p-4 text-slate-400">Aucun secteur disponible</p>';
            if (data.isGroup) return editModes[side] ? renderGroupEditModeCard(side, key, data) : renderGroupCard(side, key, data);
            return editModes[side] ? renderEditModeCard(side, key, editDrafts[side]) : renderReadOnlyCard(side, key, data);
