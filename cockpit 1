function syncWpWithActions(wid,silent=false){
  let w=wp(wid);if(!w)return;
  let acts=actionsOfWp(wid);
  let ns = w.status;
  
  if(acts.length){
    let allDone = acts.every(a=>a.status==='done' || actionPct(a)===100);
    let allPlanned = acts.every(a=>a.status==='planned');
    let anyBlocked = acts.some(a=>a.status==='blocked');
    let anyLate = acts.some(a=>effectiveStatus(a)==='late');
    
    // CORRECTION : Le WP est le reflet pur de ses actions
    if(allDone) ns='done';
    else if(anyBlocked) ns='blocked';
    else if(anyLate) ns='late';
    else if(allPlanned) ns='planned'; 
    else ns='ongoing';
  } else {
    let now = new Date();
    if (pctWp(wid)===100) ns='done';
    else if (w.status === 'blocked') ns='blocked'; 
    else if (new Date(w.end+'T23:59:59') < now) ns='late';
    else if (new Date(w.start+'T00:00:00') > now && pctWp(wid)===0) ns='planned'; 
    else ns='ongoing';
  }
  
  if(w.status!==ns){
    if(!silent)w.history.push(`${new Date().toLocaleString('fr-FR')} · Statut auto-ajusté : ${stTxt(w.status)} → ${stTxt(ns)}`);
    w.status=ns;
  }
}

