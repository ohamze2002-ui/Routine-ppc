function renderProjects(){
  let q=(document.getElementById('projectSearch')?.value||'').toLowerCase();
  document.getElementById('projectsRows').innerHTML=activeProjects().filter(p=>p.name.toLowerCase().includes(q)||cdtNames(cdtIdsOfProject(p)).toLowerCase().includes(q)||user(p.owner).name.toLowerCase().includes(q)).map(p=>{
    let pc=pctProject(p.id);
    let late=activeWps().some(w=>w.project===p.id&&effectiveStatus(w)==='late');
    let blocked=activeWps().some(w=>w.project===p.id&&effectiveStatus(w)==='blocked');
    let s=pc===100?'done':blocked?'blocked':late?'late':'ongoing';
    
    // CALCUL PROCHAIN JALON ET DATE DE FIN DE PROJET
    let allMs = [];
    let pWps = activeWps().filter(w=>w.project===p.id);
    let allDates = pWps.map(w => w.end).filter(Boolean).sort();
    let projectEnd = allDates.length ? `<span><i class="fa-regular fa-calendar-check" style="color:var(--muted)"></i> ${fmt(allDates[allDates.length-1])}</span>` : '<span style="color:var(--muted);font-size:10px;">N/A</span>';

    pWps.forEach(w => {
       allMs.push(...(w.milestones||[]));
       activeActions().filter(a=>a.wp===w.id).forEach(a => allMs.push(...(a.milestones||[])));
    });
    let todayIso = new Date().toISOString().slice(0,10);
    let futureMs = allMs.filter(m => m.date >= todayIso).sort((a,b) => a.date.localeCompare(b.date));
    let nextMs = futureMs.length ? `<span style="color:#d97706;font-weight:800;font-size:11px;"><i class="fa-solid fa-diamond"></i> ${fmt(futureMs[0].date)}</span>` : '<span style="color:var(--muted);font-size:10px;">Aucun</span>';

    return`<tr class="row-hover" onclick="openRoadmap('project','${p.id}')"><td>${p.name}</td><td>${p.sector}</td><td><div class="cdt-chip-list">${cdtIdsOfProject(p).map(id=>`<span class="chip s-planned">${cdtName(id)}</span>`).join('')}</div></td><td><span class="chip ${stClass(s)}">${stTxt(s)}</span></td><td><div class="progress"><div class="track"><div class="fill" style="width:${pc}%;background:${s==='late'?'var(--red)':pc===100?'var(--green)':s==='blocked'?'var(--dark)':'var(--blue)'}"></div></div>${pc}%</div></td><td>${projectEnd}</td><td>${nextMs}</td><td>${user(p.owner).name}</td><td><button class="btn-mini-action" onclick="event.stopPropagation();openProjectActionsPopup('${p.id}')"><i class="fa-solid fa-list-check"></i> Actions</button></td></tr>`
  }).join('');
}

function renderPeople(){
  let q=(document.getElementById('peopleSearch')?.value||'').toLowerCase();
  let selectedUsers = getDDValues('dd-list-people-filter');
  
  let filteredUsers = db.users.filter(u => {
      let matchSearch = u.name.toLowerCase().includes(q);
      let matchDD = selectedUsers.length === 0 || selectedUsers.includes(u.id);
      return matchSearch && matchDD;
  });

  document.getElementById('peopleRows').innerHTML=filteredUsers.map(u=>{
    let a=activeActions().filter(x=>x.people.includes(u.id));
    let pids=[...new Set(a.map(x=>wp(x.wp)?.project).filter(Boolean))];
    let pc=pctUser(u.id);
    let late=a.some(x=>effectiveStatus(x)==='late');
    let blocked=a.some(x=>effectiveStatus(x)==='blocked');
    let s=pc===100?'done':blocked?'blocked':late?'late':'ongoing';
    
    // CALCUL PROCHAIN JALON
    let allMs = [];
    let userWps = activeWps().filter(w=>w.owner===u.id);
    userWps.forEach(w => allMs.push(...(w.milestones||[])));
    a.forEach(act => allMs.push(...(act.milestones||[])));
    let todayIso = new Date().toISOString().slice(0,10);
    let futureMs = allMs.filter(m => m.date >= todayIso).sort((a,b) => a.date.localeCompare(b.date));
    let nextMs = futureMs.length ? `<span style="color:#d97706;font-weight:800;font-size:11px;"><i class="fa-solid fa-diamond"></i> ${fmt(futureMs[0].date)}</span>` : '<span style="color:var(--muted);font-size:10px;">Aucun</span>';

    return`<tr class="row-hover" onclick="openRoadmap('person','${u.id}')"><td>${u.name}</td><td>${u.role}</td><td>${pids.length}</td><td>${a.filter(x=>x.status!=='done').length}</td><td><span class="chip ${stClass(s)}">${stTxt(s)}</span></td><td><div class="progress"><div class="track"><div class="fill" style="width:${pc}%;background:${s==='late'?'var(--red)':pc===100?'var(--green)':s==='blocked'?'var(--dark)':'var(--blue)'}"></div></div>${pc}%</div></td><td>${nextMs}</td><td><button class="btn-mini-action" onclick="event.stopPropagation();openPersonActionsPopup('${u.id}')"><i class="fa-solid fa-list-check"></i> Actions</button></td></tr>`
  }).join('');
}

