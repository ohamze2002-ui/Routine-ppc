function updateActionDateLimits() {
  let wSelect = document.getElementById('faWp');
  if(!wSelect || wSelect.options.length === 0) return;
  
  let opt = wSelect.options[wSelect.selectedIndex];
  let wStart = opt.getAttribute('data-start');
  let wEnd = opt.getAttribute('data-end');
  
  let s = document.getElementById('faStart');
  let e = document.getElementById('faEnd');
  
  if(s && e) { 
    s.min = wStart; s.max = wEnd; 
    e.min = wStart; e.max = wEnd; 
    if(!s.value) s.value = wStart; 
    if(!e.value) e.value = wEnd; 
  }
}

