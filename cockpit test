/* CALCUL DU GANTT : HORIZON AUTO OU CADRAGE D'IMPRESSION EXACT (ZOOM OUT) */
function autoComputeTimeBounds(){
  currentPx = 10; 
  let cStart = document.getElementById('customStart')?.value;
  let cEnd = document.getElementById('customEnd')?.value;

  if (cStart && cEnd) {
     let d1 = new Date(cStart + 'T00:00:00');
     let d2 = new Date(cEnd + 'T23:59:59'); 
     if(d1 <= d2) {
         base = new Date(d1.getFullYear(), d1.getMonth(), 1); 
         // +2 mois : 1 mois pour inclure la fin du mois courant + 1 mois de marge (buffer) pour l'impression propre
         let endLimit = new Date(d2.getFullYear(), d2.getMonth() + 2, 1);
         totalMonthsCount = (endLimit.getFullYear() - base.getFullYear()) * 12 + (endLimit.getMonth() - base.getMonth());
         totalMonthsCount = Math.max(1, totalMonthsCount);
         
         let totalD = days(base, endLimit);
         let availW = Math.max(window.innerWidth - left - 60, 1600); 
         currentPx = availW / totalD; // Compression (Zoom-Out)
         
         ganttWidth = left + (totalD * currentPx) + 20; 
         return;
     }
  }

  let times = [new Date().getTime()]; 
  activeWps().forEach(w=>{
    let s = new Date(w.start).getTime(), e = new Date(w.end).getTime();
    if(!isNaN(s)) times.push(s); if(!isNaN(e)) times.push(e);
  });
  activeActions().forEach(a=>{
    let s = new Date(a.start).getTime(), e = new Date(a.end).getTime();
    if(!isNaN(s)) times.push(s); if(!isNaN(e)) times.push(e);
  });
  
  let minDate = new Date(Math.min(...times));
  let maxDate = new Date(Math.max(...times));
  
  base = new Date(minDate.getFullYear(), minDate.getMonth() - 1, 1);
  let endLimit = new Date(maxDate.getFullYear(), maxDate.getMonth() + 12, 1); 
  
  totalMonthsCount = (endLimit.getFullYear() - base.getFullYear()) * 12 + (endLimit.getMonth() - base.getMonth()) + 1;
  totalMonthsCount = Math.max(120, totalMonthsCount); 
  ganttWidth = left + (totalMonthsCount * 31 * currentPx) + 200;
}

/* RENDU DE L'EN-TÊTE TEMPOREL AVEC 52 SEMAINES EXACTES / AN */
function months(){
  let html = `<div class="g-left-head"><span>Élément</span><span>Responsable</span></div>`;
  let current = new Date(base);
  let curLeft = left;
  for(let i=0; i<totalMonthsCount; i++){
    let name = current.toLocaleString('fr-FR',{month:'long',year:'numeric'});
    let dim = new Date(current.getFullYear(),current.getMonth()+1,0).getDate();
    let width = dim*currentPx;
    html += `<div class="month" style="left:${curLeft}px;width:${width}px;height:35px;line-height:35px;border-bottom:1px solid var(--line);text-align:center;">${name}</div>`;
    curLeft += width;
    current.setMonth(current.getMonth()+1);
  }
  
  let startYear = base.getFullYear();
  let endYear = current.getFullYear();
  
  for (let y = startYear; y <= endYear; y++) {
    let yearStart = new Date(y, 0, 1);
    let yearEnd = new Date(y+1, 0, 1);
    
    let yStartLeft = left + days(base, yearStart) * currentPx;
    let yDays = days(yearStart, yearEnd); 
    let weekWidth = (yDays * currentPx) / 52; 
    
    for (let w = 1; w <= 52; w++) {
      let wkLeft = yStartLeft + (w - 1) * weekWidth;
      html += `<div style="position:absolute; top:35px; left:${wkLeft}px; width:${weekWidth}px; height:35px; line-height:35px; border-right:1px dashed var(--line); text-align:center; font-size:9px; color:var(--muted); font-weight:700; background:#fdfdfd; border-bottom:1px solid var(--line); overflow:hidden;">S${w}</div>`;
    }
  }
  
  let drawToday = true;
  let cStart = document.getElementById('customStart')?.value;
  let cEnd = document.getElementById('customEnd')?.value;
  if(cStart && cEnd) {
      let fs = new Date(cStart + 'T00:00:00'), fe = new Date(cEnd + 'T23:59:59'), today = new Date();
      if(today < fs || today > fe) drawToday = false;
  }
  if(drawToday) html += `<span class="today-label" style="left:${left+days(base,new Date())*currentPx}px; top:60px;">Aujourd'hui</span>`;
  
  return html;
}

function grids(){
  let html='';
  let current=new Date(base);
  let curLeft=left;
  for(let i=0;i<totalMonthsCount;i++){
    let dim=new Date(current.getFullYear(),current.getMonth()+1,0).getDate();
    let width=dim*currentPx;
    html+=`<span class="gridline major" style="left:${curLeft}px"></span>`;
    curLeft+=width;
    current.setMonth(current.getMonth()+1)
  }
  
  let startYear = base.getFullYear();
  let endYear = current.getFullYear();
  for (let y = startYear; y <= endYear; y++) {
    let yearStart = new Date(y, 0, 1);
    let yearEnd = new Date(y+1, 0, 1);
    let yStartLeft = left + days(base, yearStart) * currentPx;
    let yDays = days(yearStart, yearEnd);
    let weekWidth = (yDays * currentPx) / 52;
    
    for (let w = 1; w <= 52; w++) {
      let wkLeft = yStartLeft + (w - 1) * weekWidth;
      html+=`<span class="gridline" style="left:${wkLeft}px"></span>`;
    }
  }
  
  let drawToday = true;
  let cStart = document.getElementById('customStart')?.value;
  let cEnd = document.getElementById('customEnd')?.value;
  if(cStart && cEnd) {
      let fs = new Date(cStart + 'T00:00:00'), fe = new Date(cEnd + 'T23:59:59'), today = new Date();
      if(today < fs || today > fe) drawToday = false;
  }
  if(drawToday) html+=`<span class="today" style="left:${left+days(base,new Date())*currentPx}px"></span>`;
  
  return html;
}

