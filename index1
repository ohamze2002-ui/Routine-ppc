                tbody.appendChild(tr);
            });
        }

        function selectSector(side, key) {
            if (side === 'left') { activeLeftKey = key; editModes.left = false; editDrafts.left = null; } else { activeRightKey = key; editModes.right = false; editDrafts.right = null; }
            safeRenderDashboard();
        }

        function toggleEditMode(side) {
            editModes[side] = !editModes[side];
            if (editModes[side]) {
                const activeKey = (side === 'left') ? activeLeftKey : activeRightKey;
                editDrafts[side] = JSON.parse(JSON.stringify(db[activeKey] || {}));
            } else {
                editDrafts[side] = null;
            }
            safeRenderDashboard();
