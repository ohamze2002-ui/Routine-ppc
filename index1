        function captureScrollState() {
            const preserved = {};
            document.querySelectorAll('[data-preserve-scroll]').forEach(el => { preserved[el.dataset.preserveScroll] = { top: el.scrollTop || 0, left: el.scrollLeft || 0 }; });
            return { dashboard: document.getElementById('dashboard-scroll')?.scrollTop || 0, sidebar: document.querySelector('aside .overflow-y-auto')?.scrollTop || 0, leftPanel: document.getElementById('panel-zoom1')?.scrollTop || 0, rightPanel: document.getElementById('panel-zoom2')?.scrollTop || 0, preserved };
        }

        function restoreScrollState(state) {
            if (!state) return;
            if (document.getElementById('dashboard-scroll')) document.getElementById('dashboard-scroll').scrollTop = state.dashboard;
            if (document.querySelector('aside .overflow-y-auto')) document.querySelector('aside .overflow-y-auto').scrollTop = state.sidebar;
            if (document.getElementById('panel-zoom1')) document.getElementById('panel-zoom1').scrollTop = state.leftPanel;
            if (document.getElementById('panel-zoom2')) document.getElementById('panel-zoom2').scrollTop = state.rightPanel;
            Object.entries(state.preserved || {}).forEach(([k, pos]) => { const el = document.querySelector(`[data-preserve-scroll="${k}"]`); if (el) { el.scrollTop = pos.top; el.scrollLeft = pos.left; } });
        }

        function safeRenderDashboard() {
            const state = captureScrollState();
            renderDashboard();
            requestAnimationFrame(() => { restoreScrollState(state); resizeAllActionTextareas(); });
        }

        function renderDashboard() {
            const leftContainer = document.getElementById('panel-zoom1');
            const rightContainer = document.getElementById('panel-zoom2');
