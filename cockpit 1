function saveWpEdits(id){
  let w = wp(id); if(!w) return;
  let valEl = document.getElementById(`editWpComment_${id}`);
  let nameEl = document.getElementById(`editWpName_${id}`);
  let startEl = document.getElementById(`editWpStart_${id}`);
  let endEl = document.getElementById(`editWpEnd_${id}`);
  let cdtEl = document.getElementById(`editWpCdt_${id}`);
  
  let nComment = valEl ? valEl.value : (w.comment||'');
  let nName = nameEl ? nameEl.value : w.name;
  let nStart = startEl ? startEl.value : w.start;
  let nEnd = endEl ? endEl.value : w.end;
  let nCdt = cdtEl ? cdtEl.value : w.cdt;
  
  let hasChanges = (w.name !== nName || w.start !== nStart || w.end !== nEnd || w.comment !== nComment || w.cdt !== nCdt);

  if(hasChanges) {
    let r = prompt("Motif de la modification (Optionnel) :") || "Mise à jour";

    if(w.name !== nName) { w.history.push(`${new Date().toLocaleString('fr-FR')} · Nom modifié · Motif : ${r}`); w.name = nName; }
    if(w.start !== nStart || w.end !== nEnd) { w.history.push(`${new Date().toLocaleString('fr-FR')} · Dates modifiées (${w.start}→${nStart} / ${w.end}→${nEnd}) · Motif : ${r}`); w.start = nStart; w.end = nEnd; }
    if(w.comment !== nComment) { w.history.push(`${new Date().toLocaleString('fr-FR')} · Commentaire modifié · Motif : ${r}`); w.comment = nComment; }
    if(w.cdt !== nCdt) { w.history.push(`${new Date().toLocaleString('fr-FR')} · CDT modifié · Motif : ${r}`); w.cdt = nCdt; }
    
    w.modified = true;
    save('WP mis à jour');
  }
  closeModal();
}

function saveActionEdits(id){
  let a = activeActions().find(x => x.id === id); if(!a) return;
  let commEl = document.getElementById(`editActionComment_${id}`);
  let causeEl = document.getElementById(`editBlockCause_${id}`);
  let statEl = document.getElementById(`editActionStatus_${id}`);
  let progEl = document.getElementById(`editActionProgress_${id}`);
  let startEl = document.getElementById(`editActionStart_${id}`);
  let endEl = document.getElementById(`editActionEnd_${id}`);
  
  if(commEl && causeEl && statEl && progEl && startEl && endEl) {
    let nComment = commEl.value;
    let nCause = causeEl.value;
    let nStat = statEl.value;
    let nStart = startEl.value;
    let nEnd = endEl.value;
    let nProg = parseInt(progEl.value, 10);
    
    if(isNaN(nProg)) nProg = actionPct(a);
    if(nStat === 'done') nProg = 100;
    if(nProg === 100) nStat = 'done';
    if(nProg < 100 && nStat === 'done') nStat = 'ongoing';
    
    let hasChanges = (a.comment !== nComment || a.blockCause !== nCause || a.status !== nStat || actionPct(a) !== nProg || a.start !== nStart || a.end !== nEnd);

    if(hasChanges) {
      if(nStat === 'blocked' && !nCause.trim()) return alert('Cause de blocage requise.');

      let r = prompt("Motif de la modification (Optionnel) :") || "Mise à jour";

      if(a.status !== nStat) { a.history.push(`${new Date().toLocaleString('fr-FR')} · Statut: ${stTxt(a.status)} -> ${stTxt(nStat)} · Motif: ${r}`); a.status = nStat; }
      if(a.start !== nStart || a.end !== nEnd) { a.history.push(`${new Date().toLocaleString('fr-FR')} · Dates modifiées · Motif: ${r}`); a.start = nStart; a.end = nEnd; }
      if(a.comment !== nComment) { a.history.push(`${new Date().toLocaleString('fr-FR')} · Commentaire modifié · Motif: ${r}`); a.comment = nComment; }
      if(a.blockCause !== nCause) { a.history.push(`${new Date().toLocaleString('fr-FR')} · Cause blocage modifiée · Motif: ${r}`); a.blockCause = nCause; }
      if(actionPct(a) !== nProg) { a.history.push(`${new Date().toLocaleString('fr-FR')} · Avancement: ${nProg}% · Motif: ${r}`); a.progress = nProg; }
      
      syncWpWithActions(a.wp); 
      save('Action mise à jour');
    }
  }
  closeModal();
}

function saveWp(){
  let fwp = document.getElementById('fwProject')?.value;
  let fwn = document.getElementById('fwName')?.value.trim();
  let fwo = document.getElementById('fwOwner')?.value;
  let fws = document.getElementById('fwStatus')?.value;
  let fwst = document.getElementById('fwStart')?.value;
  let fwe = document.getElementById('fwEnd')?.value;
  let fwc = document.getElementById('fwComment')?.value;
  let fcdt = document.getElementById('fwCdt')?.value;
  
  if(!fwn || !fwst || !fwe) return toast('Veuillez remplir tous les champs obligatoires.');

  db.wps.push({id:uid('w'), project:fwp, name:fwn, owner:fwo, start:fwst, end:fwe, status:fws, comment:fwc, cdt:fcdt, progress:0, modified:false, archived:false, history:[`${new Date().toLocaleString('fr-FR')} · Création WP`]});
  addHistory(`WP "${fwn}"`, '-', 'Création', 'Ajout manuel');
  
  closeForm(); 
  save('WP ajouté avec succès');
}

function saveAction(){
  let faw = document.getElementById('faWp')?.value;
  let fat = document.getElementById('faTitle')?.value.trim();
  let fas = document.getElementById('faStart')?.value;
  let fae = document.getElementById('faEnd')?.value;
  let fast = document.getElementById('faStatus')?.value;
  let fab = document.getElementById('faBlock')?.value;
  let fac = document.getElementById('faComment')?.value;
  let fap = parseInt(document.getElementById('faProgress')?.value, 10);
  let people = [...document.querySelectorAll('.assignee:checked')].map(x => x.value);
  
  if(!fat || !fas || !fae || !people.length) return toast('Veuillez renseigner le nom, les dates et assigner une personne.');
  
  let w = wp(faw);
  if(new Date(fas) < new Date(w.start) || new Date(fae) > new Date(w.end)) return alert(`Erreur de dates : l'action doit être comprise entre le ${fmt(w.start)} et le ${fmt(w.end)}.`);
  if(fast === 'blocked' && !fab.trim()) return alert('Veuillez renseigner la cause du blocage.');
  
  if(isNaN(fap)) fap = 0;
  if(fast === 'done') fap = 100;
  if(fap === 100) fast = 'done';
  
  db.actions.push({id:uid('a'), wp:faw, title:fat, start:fas, end:fae, status:fast, people:people, progress:fap, comment:fac, blockCause:fab, archived:false, history:[`${new Date().toLocaleString('fr-FR')} · Création`]});
  addHistory(`Action "${fat}"`, '-', 'Création', 'Ajout manuel');
  
  syncWpWithActions(w.id); 
  closeForm();
  
  // Si la fenêtre du WP est ouverte en arrière plan, on la rafraichit
  if(document.getElementById('modal').classList.contains('show')) openWp(w.id); 
  
  save('Action ajoutée avec succès');
}

function closeForm(){ document.getElementById('formModal').classList.remove('show'); }
function closeModal(){ document.getElementById('modal').classList.remove('show'); }

function openSimple(t, body) {
  document.getElementById('modalBadge').textContent = 'Cockpit'; 
  document.getElementById('modalTitle').textContent = t; 
  document.getElementById('modalSub').textContent = '';
  document.getElementById('modalActions').innerHTML = '<button class="btn btn-white" onclick="closeModal()">Fermer</button>';
  document.getElementById('modalBody').innerHTML = body; 
  document.getElementById('modal').classList.add('show');
}

// Initialisation
showView('home');
renderAll();
</script>
