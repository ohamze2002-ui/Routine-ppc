function loadLocalData(){
    try{ return normalizeData(JSON.parse(localStorage.getItem(KEY))||demo()); }
    catch(e){ return normalizeData(demo()); }
}

function normalizeData(d){
  d.password = d.password || 'aos';
  d.cdts=d.cdts||[]; d.users=d.users||[]; d.projects=d.projects||[]; d.wps=d.wps||[]; d.actions=d.actions||[]; d.history=d.history||[];
  d.projects.forEach(p=>{if(!p.cdtIds)p.cdtIds=p.cdt?[p.cdt]:(d.cdts[0]?[d.cdts[0].id]:[]);if(!p.memberIds)p.memberIds=p.owner?[p.owner]:[];p.owner=p.owner||p.memberIds[0]||'';p.archived=!!p.archived});
  d.wps.forEach(w=>{
    let p=d.projects.find(p=>p.id===w.project);
    if(!w.cdtId) w.cdtId = w.cdt || w.cdtIds?.[0] || (p && p.cdtIds ? p.cdtIds[0] : '') || (d.cdts[0] ? d.cdts[0].id : '');
    if(!w.ownerIds)w.ownerIds=w.owner?[w.owner]:[];w.owner=w.owner||w.ownerIds[0]||'';w.archived=!!w.archived;
    if(!w.milestones) w.milestones = [];
    w.milestones.forEach(m => { if(!m.status) m.status = 'planned'; });
  });
  d.actions.forEach(a=>{
      a.people=a.people||[];a.archived=!!a.archived;if(a.progress===undefined)a.progress=0;if(!a.milestones) a.milestones = [];
      a.milestones.forEach(m => { if(!m.status) m.status = 'planned'; });
  });
  return d;
}

function save(msg){
  db.last = new Date().toLocaleString('fr-FR');
  localStorage.setItem(KEY, JSON.stringify(db));
  saveSessionCache();
  renderAll();
  if(msg) toast(msg);
}

/* === PATCH #5 : cache sessionStorage === */
function saveSessionCache(){
  try{ sessionStorage.setItem(SESSION_KEY, JSON.stringify(db)); }catch(e){ /* silencieux : cache non bloquant */ }
}
function loadSessionCache(){
  try{
    let raw = sessionStorage.getItem(SESSION_KEY);
    if(!raw) return null;
    return normalizeData(JSON.parse(raw));
  }catch(e){ return null; }
}

function uid(p){return p+Date.now()+Math.random().toString(16).slice(2)}

// REQUÊTE SÉCURISÉE VERS LE SERVEUR
window.addEventListener('DOMContentLoaded', () => {
  // PATCH #5 : affichage instantané depuis le cache sessionStorage si disponible,
  // puis synchronisation en arrière-plan avec le serveur (si Apps Script dispo).
  let cached = loadSessionCache();
  if(cached){
    db = cached;
    renderAll();
  }

  if (typeof google !== 'undefined' && google.script && google.script.run) {
    if(!cached) document.getElementById('globalLoader').style.display = 'flex';
    google.script.run
      .withSuccessHandler((response) => {
        document.getElementById('globalLoader').style.display = 'none';
        try {
          let parsed = JSON.parse(response);
          if(parsed.error) {
             if(!cached) alert("Alerte Serveur : " + parsed.error + "\n\nPassage en mode simulation locale.");
             db = cached || loadLocalData();
          } else {
             db = normalizeData(parsed);
          }
        } catch(e) {
          if(!cached) alert("Erreur de lecture des données serveur. Passage en mode local.");
          db = cached || loadLocalData();
        }
        localStorage.setItem(KEY, JSON.stringify(db));
        saveSessionCache();
        renderAll();
      })
      .withFailureHandler((err) => {
        document.getElementById('globalLoader').style.display = 'none';
        if(!cached){
          alert("Impossible de joindre Google Sheets : " + err + "\n\nPassage en mode simulation locale.");
          db = loadLocalData();
          renderAll();
        }
      })
      .getInitialData();
  } else if(!cached) {
    // Mode local pur si on est pas sur Apps Script
    db = loadLocalData();
    renderAll();
  }
});

// GESTIONNAIRE D'ENREGISTREMENT SÉCURISÉ
function pushToServer(type, payload, historyPayload, btnId, callbackOnSuccess) {
  let btn = document.getElementById(btnId);
  let oldHtml = "";
  if(btn) { 
    oldHtml = btn.innerHTML; 
    btn.disabled = true; 
    btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> Enregistrement...`; 
  }
  
  if(typeof google !== 'undefined' && google.script && google.script.run) {
    google.script.run
      .withSuccessHandler((res) => {
        if(btn) { btn.disabled = false; btn.innerHTML = oldHtml; }
        if(res && res.success) {
          db.last = res.lastUpdate;
          if(callbackOnSuccess) callbackOnSuccess();
        } else {
          alert("Erreur de sauvegarde base de données : " + (res ? res.error : 'inconnue'));
        }
      })
      .withFailureHandler((err) => {
        if(btn) { btn.disabled = false; btn.innerHTML = oldHtml; }
        alert("Rejet réseau Google : " + err + "\n\nVos données sont gardées en local.");
        if(callbackOnSuccess) callbackOnSuccess();
      })
      .updateServerData(type, payload, historyPayload);
  } else {
    setTimeout(() => {
      db.last = new Date().toLocaleString('fr-FR');
      if(btn) { btn.disabled = false; btn.innerHTML = oldHtml; }
      if(callbackOnSuccess) callbackOnSuccess();
    }, 500);
  }
}

function activeProjects(){return db.projects.filter(p=>!p.archived)}function activeWps(){let pIds=activeProjects().map(p=>p.id);return db.wps.filter(w=>!w.archived&&pIds.includes(w.project))}function activeActions(){let wIds=activeWps().map(w=>w.id);return db.actions.filter(a=>!a.archived&&wIds.includes(a.wp))}

/* SYSTÈME DE MENUS DÉROULANTS CUSTOM AVEC "SÉLECTIONNER TOUT" */
function toggleDD(id) {
  document.querySelectorAll('.dd-list').forEach(el => { if(el.id !== id) el.classList.remove('show'); });
  document.getElementById(id).classList.toggle('show');
}
window.addEventListener('click', function(e) {
  if (!e.target.closest('.dd-container')) {
    document.querySelectorAll('.dd-list').forEach(el => el.classList.remove('show'));
  }
});

function toggleAllDD(btn, listId, defaultText) {
    let list = document.getElementById(listId);
    if(!list) return;
    let cbs = list.querySelectorAll('.individual-cb');
    cbs.forEach(c => c.checked = btn.checked);
    
    // CORRECTION : On gère correctement le nommage selon si c'est un filtre ("list") ou un formulaire ("dd-")
    let txtId = listId.includes('list') ? listId.replace('list', 'txt') : listId.replace('dd-', 'txt-');
    
    // On indique "false" pour les formulaires afin de ne pas déclencher la mise à jour inutile du diagramme de Gantt
    let isFilter = listId.includes('list');
    
    updateDDText(listId, txtId, defaultText, isFilter);
    if (listId === 'dd-list-people-filter') renderPeople();
}
window.toggleAllAssignees = function(btn, listId) {
    let list = document.getElementById(listId);
    if(!list) return;
    let cbs = list.querySelectorAll('.individual-cb');
    cbs.forEach(c => c.checked = btn.checked);
    let txtId = listId.replace('dd-', 'txt-');
    updateDDText(listId, txtId, 'Sélectionner...', false);
};

function updateDDText(listId, textId, defaultText, isFilter = false) {
  let list = document.getElementById(listId);
  let headerTxt = document.getElementById(textId);
  if(!list || !headerTxt) return;
  
  let checkboxes = list.querySelectorAll('.individual-cb');
  let checked = list.querySelectorAll('.individual-cb:checked');
  
  let selectAllCb = list.querySelector('input:not(.individual-cb)');
  if(selectAllCb) selectAllCb.checked = (checkboxes.length > 0 && checked.length === checkboxes.length);

  if (isFilter) {
    if (checked.length === 0) headerTxt.textContent = defaultText;
    else headerTxt.textContent = defaultText + ' (' + checked.length + ')';
    if(listId.includes('road')) drawGantt(); 
    else drawGantt(); 
  } else {
    if (checked.length === 0) headerTxt.textContent = defaultText;
    else if (checked.length === 1) headerTxt.textContent = checked[0].parentNode.textContent.trim();
    else headerTxt.textContent = checked.length + ' sélectionnés';
  }
}
function getDDValues(listId) {
  let list = document.getElementById(listId);
  if(!list) return [];
  return [...list.querySelectorAll('.individual-cb:checked')].map(el => el.value);
}
function resetFilters() {
  document.querySelectorAll('.filters-wrap .dd-list input[type="checkbox"]').forEach(cb => cb.checked = false);
  document.getElementById('customStart').value = '';
  document.getElementById('customEnd').value = '';
  updateDDText('dd-list-cdt', 'dd-txt-cdt', 'Tous les secteurs CDT', true);
  updateDDText('dd-list-proj', 'dd-txt-proj', 'Tous les projets', true);
  updateDDText('dd-list-user', 'dd-txt-user', 'Membres d\'équipe', true);
  updateDDText('dd-list-stat', 'dd-txt-stat', 'Tous les statuts', true);
}

function user(id){return db.users.find(u=>u.id===id)||{name:'N/A',role:''}}function project(id){return db.projects.find(p=>p.id===id)}function wp(id){return db.wps.find(w=>w.id===id)}function cdtName(id){let c=db.cdts.find(x=>x.id===id);return c?c.name:'N/A'}function cdtNames(ids){return(ids||[]).map(cdtName).join(', ')||'N/A'}function memberNames(ids){return(ids||[]).map(id=>user(id).name).join(', ')||'N/A'}
function cdtIdsOfProject(p){return p&&p.cdtIds&&p.cdtIds.length?p.cdtIds:[]}function memberIdsOfProject(p){return p&&p.memberIds&&p.memberIds.length?p.memberIds:(p&&p.owner?[p.owner]:[])}function actionsOfWp(wid){return activeActions().filter(a=>a.wp===wid)}
function cdtIdOfWp(w){return w ? w.cdtId : ''}
function effectiveStatus(x){if(x.status==='done'||x.status==='blocked')return x.status;return x.end&&new Date(x.end+'T23:59:59')<new Date()?'late':x.status}
function escapeAttr(val) { return String(val ?? '').replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }
function stTxt(s){return{ongoing:'en cours',done:'terminé',late:'retard',planned:'à venir',blocked:'bloqué'}[s]||s}function stClass(s){return's-'+s}function fmt(d){if(!d)return'';let[y,m,day]=d.split('-');return`${day}/${m}/${y}`}
function actionPct(a){return a.progress!==undefined?parseInt(a.progress,10):0}function pctWp(wid){let acts=actionsOfWp(wid);if(!acts.length){let w=wp(wid);return w&&w.progress!==undefined?parseInt(w.progress,10):0}return Math.round(acts.reduce((s,x)=>s+actionPct(x),0)/acts.length)}function pctProject(pid){let wps=activeWps().filter(x=>x.project===pid);if(!wps.length)return 0;return Math.round(wps.reduce((a,x)=>a+pctWp(x.id),0)/wps.length)}function pctUser(uid){let acts=activeActions().filter(x=>x.people.includes(uid));if(!acts.length)return 0;return Math.round(acts.reduce((s,x)=>s+actionPct(x),0)/acts.length)}
function addHistory(object,oldVal,newVal,reason,userName='Omar Hamzé'){db.history.unshift({date:new Date().toLocaleString('fr-FR'),user:userName,object,old:oldVal,new:newVal,reason:reason||'Mise à jour'})}
function toast(t){let e=document.getElementById('toast');if(e){e.textContent=t;e.classList.add('show');setTimeout(()=>e.classList.remove('show'),2500)}}

