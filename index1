        function scoreColor(score) {
            if (score >= 75) return 'bar-green';
            if (score >= 55) return 'bar-blue';
            if (score >= 35) return 'bar-amber';
            return 'bar-red';
        }

        function gradeFromScore(score) {
            if (score >= 75) return 'A';
            if (score >= 55) return 'B';
            if (score >= 35) return 'C';
            return 'D';
        }

        function gradeMeta(grade) {
            const g = String(grade || 'C').toUpperCase();
            if (g === 'A') return { grade: 'A', cls: 'grade-a', label: 'Maturité A' };
            if (g === 'B') return { grade: 'B', cls: 'grade-b', label: 'Maturité B' };
            if (g === 'D') return { grade: 'D', cls: 'grade-d', label: 'Maturité D' };
            return { grade: 'C', cls: 'grade-c', label: 'Maturité C' };
        }

        function renderMaturityBadge(data) {
            const meta = gradeMeta(data?.maturityGrade || gradeFromScore(getOverallScore(data?.maturity)));
            return `<span class="maturity-badge ${meta.cls}" title="${meta.label}">${meta.grade}</span>`;
        }

        function renderMaturitySelect(side, key, data) {
            const g = (data?.maturityGrade || gradeFromScore(getOverallScore(data?.maturity))).toUpperCase();
            return `
                <div class="flex items-center gap-2 shrink-0">
                    <span class="text-xs font-extrabold text-slate-400 uppercase">Maturité</span>
                    <select onchange="editMaturityGrade('${side}', '${key}', this.value)" class="border border-slate-200 rounded-lg px-2 py-1 text-sm font-extrabold text-slate-800 bg-white outline-none focus:border-blue-500">
                        ${['A','B','C','D'].map(x => `<option value="${x}" ${x===g?'selected':''}>${x}</option>`).join('')}
                    </select>
                </div>
            `;
        }

        function average(values) {
            const clean = values.filter(v => typeof v === 'number' && !Number.isNaN(v));
            return clean.length ? Math.round(clean.reduce((a,b)=>a+b,0) / clean.length) : 0;
        }

        function getRoutineScore(maturity, type) {
            return average(Object.values(maturity?.[type] || {}));
        }

        function getOverallScore(maturity) {
            return average([getRoutineScore(maturity, 'daily'), getRoutineScore(maturity, 'weekly')]);
        }

        function generateMaturityFromRoutine(routine, type) {
            const pts = routine?.pts || [];
            const ok = pts.filter(p => p.status === 'v').length;
            const ratio = pts.length ? Math.round((ok / pts.length) * 100) : 50;
            const base = Math.max(20, Math.min(95, ratio + ((routine?.prep || []).length + (routine?.routine || []).length > 6 ? -10 : 0) + (routine?.irr ? -12 : 5)));
            return type === 'daily'
                ? { avanceRetard: Math.max(20, Math.min(95, base + 5)), aleas: Math.max(20, Math.min(95, base - 5)), decision: Math.max(20, Math.min(95, base)) }
                : { performance: Math.max(20, Math.min(95, base + 5)), paretoAleas: Math.max(20, Math.min(95, base)), planAction: Math.max(20, Math.min(95, base - 10)) };
        }

        function defaultActionsForSector(sector) {
            return {
                daily: [{ criteria: 'Suivi avance / retard', action: 'Clarifier le support de pilotage utilisé pendant le Daily', status: 'not_started' }, { criteria: 'Écarts routine', action: 'Valider les irritants terrain et les écarts observés', status: 'ongoing' }],
                weekly: [{ criteria: 'Plan d’action', action: 'Relier les aléas / KPI Weekly à un plan d’action suivi', status: 'not_started' }, { criteria: 'Sources KPI', action: 'Clarifier les sources de données CVAT / performance / aléas', status: 'ongoing' }]
            };
        }

        function enrichDatabase(database) {
            // CORRECTION 1 : On boucle en premier sur tous les sous-secteurs pour que les totaux soient calculés avant d'attaquer les synthèses
            Object.keys(database).forEach(key => {
                if (GROUP_STRUCTURE[key]) return;
                const sector = database[key];
                if (!sector) return;
                sector.group = ((sector.name || '').replace(/\s+/g,'').toLowerCase().match(/ody[els]/)?.[0] || '').toUpperCase();
                sector.superGroup = 'ODY';
                sector.isGroup = false;
                if (!sector.maturity) sector.maturity = { daily: generateMaturityFromRoutine(sector.daily, 'daily'), weekly: generateMaturityFromRoutine(sector.weekly, 'weekly') };
                if (!sector.maturityGrade) sector.maturityGrade = gradeFromScore(getOverallScore(sector.maturity));
                if (!sector.actions) sector.actions = defaultActionsForSector(sector);
            });
            // Étape 2 : On compile maintenant les synthèses à l'ouverture, tout est déjà pré-calculé !
            Object.keys(GROUP_STRUCTURE).forEach(groupKey => { database[groupKey] = buildGroupNode(groupKey, database); });
        }

        function buildGroupNode(groupKey, database) {
            const cfg = GROUP_STRUCTURE[groupKey];
            const existing = database[groupKey] || {};
            const childKeys = getLeafChildrenForStructure(groupKey);
            const childMaturities = childKeys.map(k => database[k]).filter(Boolean).map(c => c.maturity).filter(Boolean);
            const computedMaturity = { daily: {}, weekly: {} };
            ['avanceRetard','aleas','decision'].forEach(k => computedMaturity.daily[k] = average(childMaturities.map(m => m.daily?.[k])));
            ['performance','paretoAleas','planAction'].forEach(k => computedMaturity.weekly[k] = average(childMaturities.map(m => m.weekly?.[k])));
            return {
                name: cfg.name,
                title: existing.title || cfg.title,
                isGroup: true,
                group: cfg.name,
                superGroup: cfg.superGroup,
                children: cfg.children,
                maturity: computedMaturity,
                maturityGrade: existing.maturityGrade || gradeFromScore(getOverallScore(computedMaturity))
            };
        }

        function getLeafChildrenForStructure(groupKey) {
            const cfg = GROUP_STRUCTURE[groupKey]; if (!cfg) return [groupKey];
            let res = []; cfg.children.forEach(ck => { if (GROUP_STRUCTURE[ck]) res = res.concat(getLeafChildrenForStructure(ck)); else res.push(ck); }); return res;
        }

        function orderedKeysForSidebar() {
            const order = ['ody', 'odye', 'odye1', 'odye2', 'odys', 'odys1', 'odys2', 'odys3', 'odys41', 'odys42', 'odyl', 'odyl1', 'odyl2', 'odyl3'];
            return order.filter(k => db[k]).concat(Object.keys(db).filter(k => !order.includes(k)));
        }

        let db = {};
        let activeLeftKey = "odyl1";
        let activeRightKey = "odyl2";
        let editModes = { left: false, right: false };
        let editDrafts = { left: null, right: null };
        let isServerReady = false;

        function isAppsScriptRuntime() { return typeof google !== 'undefined' && google.script && google.script.run; }

        function showLoadingState(message = "Chargement des donnees PPC...") {
            const leftContainer = document.getElementById('panel-zoom1');
            const rightContainer = document.getElementById('panel-zoom2');
            const divider = document.getElementById('panel-divider');
            if (divider) divider.classList.add('hidden');
            if (rightContainer) rightContainer.classList.add('hidden');
            if (leftContainer) {
                leftContainer.className = "flex-grow w-full flex flex-col gap-4 fade-in";
                leftContainer.innerHTML = `<div class="flex-grow flex flex-col items-center justify-center text-slate-500 border-2 border-dashed border-slate-200 rounded-xl p-8 bg-white"><i class="fa-solid fa-database text-4xl mb-3 text-blue-500"></i><p class="text-sm font-bold">${message}</p><p class="text-xs text-slate-400 mt-1">Connexion a la base Google Sheet...</p></div>`;
            }
        }

        function getSerializableDb() {
            const copy = JSON.parse(JSON.stringify(db || {}));

            if (typeof GROUP_STRUCTURE !== 'undefined') {
                Object.keys(GROUP_STRUCTURE).forEach(gk => {
                    if (copy[gk]) {
                        copy[gk] = {
                            title: copy[gk].title,
                            maturityGrade: copy[gk].maturityGrade
                        };
                    }
                });
            }

            return copy;
        }

        function initApp() {
            showLoadingState("Connexion et lecture de la base PPC...");
            if (isAppsScriptRuntime()) {
                google.script.run
                    .withSuccessHandler(response => {
                        try {
                            isServerReady = true;
                            if (response && response.ok && response.data) {
                                db = response.data;
                                enrichDatabase(db);
                                const keys = Object.keys(db);
                                if (!keys.includes(activeLeftKey)) activeLeftKey = keys[0] || "";
                                if (!keys.includes(activeRightKey)) activeRightKey = keys[1] || keys[0] || "";
                                renderSidebar();
                                renderDashboard();
                            } else {
                                db = JSON.parse(JSON.stringify(DEFAULT_DATABASE));
                                enrichDatabase(db);
                                const payload = getSerializableDb();
                                if (isAppsScriptRuntime()) google.script.run.saveData(payload);
                            }
                        } catch (e) { applyLoadedDatabase(null); }
                    })
                    .withFailureHandler(() => { applyLoadedDatabase(null); })
                    .getData();
                return;
            }
            const savedDb = localStorage.getItem('ppc_sectors_db_custom_v6');
            applyLoadedDatabase(savedDb ? JSON.parse(savedDb) : null);
        }

        function applyLoadedDatabase(loadedDb) {
            db = (loadedDb && typeof loadedDb === 'object' && Object.keys(loadedDb).length > 0) ? loadedDb : JSON.parse(JSON.stringify(DEFAULT_DATABASE));
            enrichDatabase(db);
            const keys = Object.keys(db);
            if (!keys.includes(activeLeftKey)) activeLeftKey = "odyl1";
            if (!keys.includes(activeRightKey)) activeRightKey = "odyl2";
            renderSidebar();
            renderDashboard();
        }

        function resetToDefaults() {
            activeLeftKey = "odyl1"; activeRightKey = "odyl2"; editModes.left = false; editModes.right = false;
            editDrafts.left = null; editDrafts.right = null;
            db = JSON.parse(JSON.stringify(DEFAULT_DATABASE));
            enrichDatabase(db);
            const payload = getSerializableDb();
            if (isAppsScriptRuntime()) google.script.run.saveData(payload);
            else localStorage.setItem('ppc_sectors_db_custom_v6', JSON.stringify(payload));
            closeResetConfirmModal();
            renderSidebar();
            renderDashboard();
        }

        function renderSidebar() {
            const tbody = document.getElementById('sectors-table-body');
            tbody.innerHTML = '';
