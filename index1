                leftContainer.className = "flex-grow w-full flex flex-col gap-4 fade-in"; leftContainer.innerHTML = createCardHTML('left', activeLeftKey);
            } else {
                if (divider) divider.classList.remove('hidden'); if (rightContainer) rightContainer.classList.remove('hidden');
                leftContainer.className = "flex-1 flex flex-col gap-4 fade-in"; rightContainer.className = "flex-1 flex flex-col gap-4 fade-in";
                leftContainer.innerHTML = createCardHTML('left', activeLeftKey); rightContainer.innerHTML = createCardHTML('right', activeRightKey);
            }
