window._actionsPopupData = {};
function filterActionsPopup(popupId){
  let all = window._actionsPopupData[popupId] || [];
  let q = (document.getElementById(`${popupId}-search`)?.value||'').toLowerCase();
  let st = document.getElementById(`${popupId}-status`)?.value||'';
  let cdt = document.getElementById(`${popupId}-cdt`)?.value||'';
  let sort = document.getElementById(`${popupId}-sort`)?.value||'date';

  let filtered = all.filter(r=>{
    let matchQ = !q || r.action.title.toLowerCase().includes(q) || r.resp.toLowerCase().includes(q) || (r.project?.name||'').toLowerCase().includes(q) || (r.wp?.name||'').toLowerCase().includes(q);
    let matchSt = !st || effectiveStatus(r.action)===st;
    let matchCdt = !cdt || r.cdt===cdt;
    return matchQ && matchSt && matchCdt;
  });

  const urgencyRank = {blocked:0, late:1, ongoing:2, planned:3, done:4};
  if(sort==='urgency') filtered.sort((a,b)=> (urgencyRank[effectiveStatus(a.action)] ?? 9) - (urgencyRank[effectiveStatus(b.action)] ?? 9) || (a.action.end||'').localeCompare(b.action.end||''));
  else if(sort==='end_asc') filtered.sort((a,b)=> (a.action.end||'').localeCompare(b.action.end||''));
  else if(sort==='progress_asc') filtered.sort((a,b)=> actionPct(a.action) - actionPct(b.action));
  else if(sort==='project') filtered.sort((a,b)=> (a.project?.name||'').localeCompare(b.project?.name||''));

  renderActionsPopupTable(filtered, `${popupId}-body`);
}
