                    <td class="py-3 pr-4 text-right">${item.isGroup ? '<span class="text-slate-300 text-xs">—</span>' : `<button onclick="confirmDeleteSector('${key}')" class="text-slate-300 hover:text-rose-500 p-1 rounded transition opacity-0 group-hover:opacity-100 focus:opacity-100"><i class="fa-solid fa-trash-can text-sm"></i></button>`}</td>
