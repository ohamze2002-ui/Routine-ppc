<div id="modal" class="modal">
  <div class="panel simple-panel">
    <div class="modal-head"><div><span id="modalBadge" class="chip s-ongoing">Détail</span><h2 id="modalTitle" style="margin-top:8px">Titre</h2><div id="modalSub" class="modal-sub"></div></div><div class="actions" id="modalActions"></div></div>
    <div class="modal-body" id="modalBody"></div>
  </div>
