function saveWpEdits(id){
  let w=wp(id);let p=project(w.project);let nName=document.getElementById(`editWpName_${id}`).value;
  let nStart=document.getElementById(`editWpStart_${id}`).value;let nEnd=document.getElementById(`editWpEnd_${id}`).value;
  let nComment=document.getElementById(`editWpComment_${id}`).value;let nCdtId=document.getElementById(`editWpCdtSelect_${id}`).value;
  let nStat=document.getElementById(`editWpStatus_${id}`).value;
  
  if(new Date(nStart) > new Date(nEnd)) return alert("Erreur : La date de début ne peut pas être ultérieure à la date de fin.");
  
  let newMs = [];
  document.querySelectorAll('#wp-milestones-area .milestone-row').forEach(r => {
     let n = r.querySelector('.ms-name').value.trim();
     let d = r.querySelector('.ms-date').value;
     let s = r.querySelector('.ms-status').value;
     if(n && d) newMs.push({name:n, date:d, status:s});
  });
  
  let invalidMs = newMs.some(m => m.date < nStart || m.date > nEnd);
  if(invalidMs) return alert(`Erreur : Tous les jalons doivent être compris dans les dates du WP (du ${fmt(nStart)} au ${fmt(nEnd)}).`);

  let msChanged = JSON.stringify(w.milestones) !== JSON.stringify(newMs);
  let changed=w.name!==nName||w.start!==nStart||w.end!==nEnd||w.comment!==nComment||w.cdtId!==nCdtId||w.status!==nStat||msChanged;
  
  if(changed){
    let r = "";
    if (nStat === 'blocked' || nStat === 'done') {
      r = "Mise à jour statut forcée manuellement";
    } else {
      while (!r || !r.trim()) {
        r = prompt('Motif de la modification (OBLIGATOIRE) :');
        if (r === null) return; 
      }
    }
    
    let acts = activeActions().filter(a => a.wp === id);
    let oStart = new Date(w.start); let nS = new Date(nStart);
    let oEnd = new Date(w.end); let nE = new Date(nEnd);

    if (w.start !== nStart) {
      acts.forEach(a => {
        let aS = new Date(a.start), aE = new Date(a.end);
        if (nS > oStart) { 
          if (aE >= oStart && aE <= nS) {
            a.archived = true; 
            a.history.push(`${new Date().toLocaleString('fr-FR')} · Auto-suppression : Le WP démarre désormais après la fin de l'action.`);
          } else if (aS >= oStart && aS < nS) {
            a.start = nStart; 
            a.history.push(`${new Date().toLocaleString('fr-FR')} · Auto-ajustement : Date début calée sur le WP.`);
          }
        }
      });
    }
    
    if (w.end !== nEnd) {
      acts.forEach(a => {
        if (a.archived) return; 
        let aS = new Date(a.start), aE = new Date(a.end);
        if (nE < aS) { 
          a.archived = true; 
          a.history.push(`${new Date().toLocaleString('fr-FR')} · Auto-suppression : Le WP se termine avant le début de l'action.`);
        } else if (aE > nE) { 
          a.end = nEnd; 
          a.history.push(`${new Date().toLocaleString('fr-FR')} · Auto-ajustement : Date fin tronquée sur le WP.`);
        }
      });
    }

    w.milestones = newMs;

    if(nStat === 'done') {
        w.progress = 100;
        acts.forEach(a => { a.status = 'done'; a.progress = 100; });
    } else if (nStat === 'planned' && w.progress === 100) {
        w.progress = 0;
    }
    
    w.history.push(`${new Date().toLocaleString('fr-FR')} · Modification WP · Motif : ${r}`);
    
    let oldValStr = []; let newValStr = [];
    if(w.name!==nName){oldValStr.push(`Nom: ${w.name}`);newValStr.push(`Nom: ${nName}`);}
    if(w.start!==nStart){oldValStr.push(`Début: ${fmt(w.start)}`);newValStr.push(`Début: ${fmt(nStart)}`);}
    if(w.end!==nEnd){oldValStr.push(`Fin: ${fmt(w.end)}`);newValStr.push(`Fin: ${fmt(nEnd)}`);}
    if(w.status!==nStat){oldValStr.push(`Statut: ${stTxt(w.status)}`);newValStr.push(`Statut: ${stTxt(nStat)}`);}
    if(w.cdtId!==nCdtId){oldValStr.push(`Secteur: ${cdtName(w.cdtId)}`);newValStr.push(`Secteur: ${cdtName(nCdtId)}`);}
    if(w.comment!==nComment){oldValStr.push(`Commentaire modifié`);newValStr.push(`Commentaire modifié`);}
    
    if(msChanged){
        let oldMsStr = (w.milestones||[]).map(m => `${m.name} [${m.status==='done'?'Terminé':'À venir'}]`).join(', ') || 'Aucun';
        let newMsStr = newMs.map(m => `${m.name} [${m.status==='done'?'Terminé':'À venir'}]`).join(', ') || 'Aucun';
        oldValStr.push(`Jalons: ${oldMsStr}`); newValStr.push(`Jalons: ${newMsStr}`);
    }
    
    w.name=nName;w.start=nStart;w.end=nEnd;w.comment=nComment;w.cdtId=nCdtId;w.status=nStat;w.modified=true;
    addHistory(`WP "${w.name}" (Projet: ${p.name}, Secteur: ${cdtName(nCdtId)})`, oldValStr.join(' | '), newValStr.join(' | '), r);
    save('WP mis à jour');
  }
  
  closeModal();
  drawGantt(); 
}

/* === PATCH #2 : réécriture complète et robuste de saveActionEdits === */
function saveActionEdits(id){
  let a = activeActions().find(x => x.id === id);
  if(!a){ toast('Action introuvable (elle a peut-être été archivée).'); return; }
  let w = wp(a.wp);
  if(!w){ toast('WP parent introuvable.'); return; }
  let p = project(w.project);

  let elComment = document.getElementById(`editActionComment_${id}`);
  let elCause = document.getElementById(`editBlockCause_${id}`);
  let elStatus = document.getElementById(`editActionStatus_${id}`);
  let elProgress = document.getElementById(`editActionProgress_${id}`);
  let elStart = document.getElementById(`editActionStart_${id}`);
  let elEnd = document.getElementById(`editActionEnd_${id}`);
  if(!elComment || !elCause || !elStatus || !elProgress || !elStart || !elEnd){
    toast('Le formulaire semble avoir été fermé, réessayez.');
    return;
  }

  let nComment = elComment.value;
  let nCause = elCause.value;
  let nStat = elStatus.value;
  let nProg = parseInt(elProgress.value, 10);
  let nStart = elStart.value;
  let nEnd = elEnd.value;

  if(isNaN(nProg)) nProg = actionPct(a);
  nProg = Math.max(0, Math.min(100, nProg));

  // Règles métier statut <-> avancement
  if(nStat === 'done') nProg = 100;
  if(nProg === 100) nStat = 'done';

  // Validations de dates (Action strictement < et dans les bornes du WP)
  if(!nStart || !nEnd) return alert("Erreur : les dates de début et de fin sont obligatoires.");
  if(new Date(nStart) >= new Date(nEnd)) return alert("Erreur : la date de début doit être strictement avant la date de fin.");
  if(new Date(nStart) < new Date(w.start) || new Date(nEnd) > new Date(w.end)) return alert(`Erreur : les dates de l'action doivent être comprises dans celles du WP (du ${fmt(w.start)} au ${fmt(w.end)}).`);

  // Jalons : lecture sans muter le DOM de manière incohérente
  let newMs = [];
  document.querySelectorAll('#action-milestones-area .milestone-row').forEach(r => {
    let n = r.querySelector('.ms-name').value.trim();
    let d = r.querySelector('.ms-date').value;
    let s = r.querySelector('.ms-status').value;
    if(n && d) newMs.push({name:n, date:d, status:s});
  });
  let invalidMs = newMs.some(m => m.date < nStart || m.date > nEnd);
  if(invalidMs) return alert(`Erreur : tous les jalons de l'action doivent être compris entre le ${fmt(nStart)} et le ${fmt(nEnd)}.`);

  // Personnes assignées : on ne trie JAMAIS le tableau source (a.people) par effet de bord.
  // On construit une copie triée pour la comparaison uniquement.
  let nPeople = [...document.querySelectorAll(`#dd-edit-people_${id} .edit-assignee:checked`)].map(x => x.value);
  if(!nPeople.length) return toast('Il faut au moins une personne assignée.');

  if(nStat === 'blocked' && !nCause.trim()) return alert('Cause de blocage requise quand le statut est "Bloqué".');

  let oldPeopleSorted = [...a.people].sort();
  let newPeopleSorted = [...nPeople].sort();
  let peopleChanged = JSON.stringify(oldPeopleSorted) !== JSON.stringify(newPeopleSorted);

  let msChanged = JSON.stringify(a.milestones || []) !== JSON.stringify(newMs);
  let changed = a.comment !== nComment || a.blockCause !== nCause || a.status !== nStat ||
                actionPct(a) !== nProg || a.start !== nStart || a.end !== nEnd ||
                msChanged || peopleChanged;

  if(!changed){
    closeModal();
    drawGantt();
    return;
  }

  let r = "";
  if(nStat === 'blocked'){
    r = "Mise à jour statut / Cause blocage : " + nCause;
  } else {
    while(!r || !r.trim()){
      r = prompt('Motif de la modification (OBLIGATOIRE) :');
      if(r === null) return;
    }
  }

  // Historique lisible avant / après
  let oldValStr = []; let newValStr = [];
  if(a.start !== nStart){ oldValStr.push(`Début: ${fmt(a.start)}`); newValStr.push(`Début: ${fmt(nStart)}`); }
  if(a.end !== nEnd){ oldValStr.push(`Fin: ${fmt(a.end)}`); newValStr.push(`Fin: ${fmt(nEnd)}`); }
  if(a.status !== nStat){ oldValStr.push(`Statut: ${stTxt(a.status)}`); newValStr.push(`Statut: ${stTxt(nStat)}`); }
  if(actionPct(a) !== nProg){ oldValStr.push(`Avancement: ${actionPct(a)}%`); newValStr.push(`Avancement: ${nProg}%`); }
  if(a.comment !== nComment){ oldValStr.push(`Commentaire modifié`); newValStr.push(`Commentaire modifié`); }
  if(a.blockCause !== nCause){ oldValStr.push(`Cause Blocage modifiée`); newValStr.push(`Cause Blocage modifiée`); }
  if(peopleChanged){
    let oldPStr = a.people.map(pid => user(pid).name).join(', ') || 'Aucun';
    let newPStr = nPeople.map(pid => user(pid).name).join(', ') || 'Aucun';
    oldValStr.push(`Équipe: ${oldPStr}`); newValStr.push(`Équipe: ${newPStr}`);
  }
  if(msChanged){
    let oldMsStr = (a.milestones || []).map(m => `${m.name} [${m.status === 'done' ? 'Terminé' : 'À venir'}]`).join(', ') || 'Aucun';
    let newMsStr = newMs.map(m => `${m.name} [${m.status === 'done' ? 'Terminé' : 'À venir'}]`).join(', ') || 'Aucun';
    oldValStr.push(`Jalons: ${oldMsStr}`); newValStr.push(`Jalons: ${newMsStr}`);
  }

  // Application des changements DIRECTEMENT sur l'objet référencé dans db.actions
  a.comment = nComment;
  a.blockCause = nCause;
  a.status = nStat;
  a.progress = nProg;
  a.start = nStart;
  a.end = nEnd;
  a.people = nPeople; // nouveau tableau, aucune mutation par effet de bord de l'ancien
  a.milestones = newMs;
  a.history = a.history || [];
  a.history.push(`${new Date().toLocaleString('fr-FR')} · Modification action · Motif : ${r}`);

  // Resynchronisation du WP parent (statut / avancement dérivés des actions)
  syncWpWithActions(a.wp);

  addHistory(`Action "${a.title}" (WP: ${w.name}, Projet: ${p.name})`, oldValStr.join(' | '), newValStr.join(' | '), r);

  pushToServer('action', a, {user:'Omar Hamzé', object:`Modif Action "${a.title}"`, old:oldValStr.join(' | '), new:newValStr.join(' | '), reason:r}, null, () => {
    save('Action mise à jour');
    // Si la popup WP parent est toujours ouverte derrière, on rafraîchit son tableau + le Gantt
    if(document.getElementById('modal').classList.contains('show')){
      closeModal();
    }
    drawGantt();
  });
}

function saveWp(){
  let p=project(document.getElementById('fwProject').value);let wpCdtIds=getDDValues('dd-fw-cdt');
  let fwName=document.getElementById('fwName').value.trim(); let fwStart=document.getElementById('fwStart').value; let fwEnd=document.getElementById('fwEnd').value;
  if(!fwName||!fwStart||!fwEnd)return toast('Veuillez remplir les champs obligatoires.');
  if(new Date(fwStart) > new Date(fwEnd)) return alert("Erreur : La date de début ne peut pas être ultérieure à la date de fin.");
  if(!wpCdtIds.length)return toast('Sélectionnez au moins un CDT.');
  
  wpCdtIds.forEach(selectedCdtId => {
    let wId=uid('w');
    db.wps.push({
      id:wId,project:p.id,name:fwName,owner:document.getElementById('fwOwner').value,ownerIds:[document.getElementById('fwOwner').value],
      cdtId:selectedCdtId,start:fwStart,end:fwEnd,status:document.getElementById('fwStatus').value,
      comment:document.getElementById('fwComment').value,progress:0,modified:false,archived:false,milestones:[],
      history:[`${new Date().toLocaleString('fr-FR')} · Création WP pour CDT ${cdtName(selectedCdtId)}`]
    });
  });
  
  addHistory(`WP Multi-CDT "${fwName}"`,'-','Création groupée',`Création sans action automatique.`);
  closeForm();save('Work Package créé.');
}

/* === PATCH #1 : après création d'une action depuis un WP, on synchronise et on rafraîchit tout === */
function saveAction(){
  let people=[...document.querySelectorAll('.assignee:checked')].map(x=>x.value); let w=wp(document.getElementById('faWp').value); let p=project(w.project);
  let faTitle=document.getElementById('faTitle').value.trim(); let faStart=document.getElementById('faStart').value; let faEnd=document.getElementById('faEnd').value;
  let prog=parseInt(document.getElementById('faProgress').value,10); if(isNaN(prog)) prog=0;
  if(!faTitle||!faStart||!faEnd||!people.length) return toast('Renseigne nom, dates et personnes.');
  if(new Date(faStart) >= new Date(faEnd)) return alert("Erreur : la date de début doit être strictement avant la date de fin.");
  if(new Date(faStart)<new Date(w.start)||new Date(faEnd)>new Date(w.end))return alert(`Erreur : l'action doit être comprise entre le ${fmt(w.start)} et le ${fmt(w.end)} (les limites du WP).`);
  
  let st=document.getElementById('faStatus').value; if(st==='done') prog=100; if(prog===100) st='done';
  if(st==='blocked' && !document.getElementById('faBlock').value.trim()) return alert('Cause de blocage requise.');
  let payload = {id:uid('a'), wp:w.id, title:faTitle, start:faStart, end:faEnd, status:st, people:people, progress:prog, comment:document.getElementById('faComment').value, blockCause:document.getElementById('faBlock').value, milestones:[], archived:false, history:[`${new Date().toLocaleString('fr-FR')} · Création de l'action`]};
  
  db.actions.push(payload);
  syncWpWithActions(w.id);
  pushToServer('action', payload, {user:'Omar Hamzé', object:`Création Action "${faTitle}"`, old:'-', new:w.name, reason:'Nouveau'}, 'formBody', () => {
    closeForm();
    save('Action ajoutée');
    // Si la popup du WP parent est ouverte, on la rafraîchit directement (tableau Actions liées + Gantt)
    let modalOpen = document.getElementById('modal').classList.contains('show');
    let modalTitleMatchesWp = document.getElementById('modalTitle')?.textContent === w.name;
    if(modalOpen && modalTitleMatchesWp){
      openWp(w.id);
    }
    if(document.getElementById('roadModal').classList.contains('show')) drawGantt();
  });
}

