                    <div class="flex flex-col gap-2 max-h-[320px] overflow-y-auto">
                        ${actions.length ? actions.map(a => { const meta = getActionStatusMeta(a.status); return `<div class="bg-blue-50/40 border border-blue-100 rounded-lg px-3 py-2"><div class="flex items-center justify-between text-[10px] font-extrabold text-blue-600"><span>${a.sector} — ${a.type}</span><span class="${meta.cls}">${meta.label}</span></div><div class="text-xs font-extrabold text-slate-800 mt-1">${a.criteria}</div><div class="text-xs text-slate-600 mt-0.5 leading-snug">${a.action}</div></div>`; }).join('') : '<p class="text-xs text-slate-400 italic">Aucune action ouverte</p>'}
                    </div>
                </div>
            `;
        }

        function renderGroupCard(side, key, data) {
