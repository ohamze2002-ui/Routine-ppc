function autoComputeTimeBounds() {
  let dates = [new Date()]; // force inclure "aujourd'hui"
  activeWps().forEach(w => { if(w.start) dates.push(new Date(w.start)); if(w.end) dates.push(new Date(w.end)); });
  activeActions().forEach(a => { if(a.start) dates.push(new Date(a.start)); if(a.end) dates.push(new Date(a.end)); });
  
  let minDate = new Date(Math.min(...dates));
  let maxDate = new Date(Math.max(...dates));
  if(isNaN(minDate.getTime())) { minDate = new Date(); maxDate = new Date(); }
  
  // Demarre 1 mois avant la toute premiere date trouvee
  base = new Date(minDate.getFullYear(), minDate.getMonth() - 1, 1);
  
  // Genere 120 mois (10 ans pleins) pour s'assurer que ça ne bloque jamais visuellement
  let endLimit = new Date(maxDate.getFullYear() + 10, maxDate.getMonth(), 1); 
  let diffMonths = (endLimit.getFullYear() - base.getFullYear()) * 12 + (endLimit.getMonth() - base.getMonth());
  
  totalMonthsCount = Math.max(120, diffMonths); 
  ganttWidth = left + (totalMonthsCount * 31 * px);
}

function scrollToToday() {
  let gtWrap = document.querySelector('.gantt-wrap');
  if(gtWrap) {
    let tx = xpos(new Date());
    gtWrap.scrollLeft = tx - (gtWrap.clientWidth / 2);
  }
}

function days(a, b) { return Math.round((b - a) / 86400000); }
function xpos(d) { return left + days(base, new Date(d)) * px; }
function wpx(s, e) { return Math.max(24, (days(new Date(s), new Date(e)) + 1) * px); }

function months(){
  let html = `<div class="g-left-head"><span>Élément</span><span>Responsable</span></div>`;
  let current = new Date(base);
  let currentLeft = left;
  for (let i = 0; i < totalMonthsCount; i++) {
    let name = current.toLocaleString('fr-FR', { month: 'long', year: 'numeric' });
    let daysInMonth = new Date(current.getFullYear(), current.getMonth() + 1, 0).getDate();
    let width = daysInMonth * px;
    html += `<div class="month" style="left:${currentLeft}px; width:${width}px;">${name}</div>`;
    currentLeft += width;
    current.setMonth(current.getMonth() + 1);
  }
  html += `<span class="today-label" style="left:${left+days(base,new Date())*px}px">Aujourd'hui</span>`;
  return html;
}

function grids(){
  let html = '';
  let current = new Date(base);
  let currentLeft = left;
  for (let i = 0; i < totalMonthsCount; i++) {
    let daysInMonth = new Date(current.getFullYear(), current.getMonth() + 1, 0).getDate();
    let width = daysInMonth * px;
    html += `<span class="gridline major" style="left:${currentLeft}px"></span>`;
    html += `<span class="gridline" style="left:${currentLeft + (Math.round(daysInMonth/2) * px)}px"></span>`;
    currentLeft += width;
    current.setMonth(current.getMonth() + 1);
  }
  html += `<span class="today" style="left:${left+days(base,new Date())*px}px"></span>`;
  return html;
}

function groupBy(items,key){
  let map = {}; 
  items.forEach(i => { let k = key(i) || 'Autre'; (map[k] = map[k] || []).push(i); }); 
  return map;
}

function initials(name){ 
  return (name||'').split(' ').filter(Boolean).slice(0,2).map(x=>x[0]).join('').toUpperCase(); 
}

// ALGORITHME DU GANTT : FUSION ET ANTI-DOUBLON
function drawGantt(){
  let items = []; 
  let filtCdt = document.getElementById('fCdt')?.value || '';
  let filtProj = document.getElementById('fProj')?.value || '';
  let filtPerson = document.getElementById('fPerson')?.value || '';
  let filtStatus = document.getElementById('fStatus')?.value || '';

  activeWps().forEach(w => {
    let p = project(w.project); 
    if (!p) return;
    
    // Conditions de filtrage Global
    let mProj = !filtProj || w.project === filtProj;
    let mCdt = !filtCdt || w.cdt === filtCdt || p.cdt === filtCdt;
    let mStatus = !filtStatus || effectiveStatus(w) === filtStatus;
    let mPerson = !filtPerson || w.owner === filtPerson;

    // Conditions de filtrage des actions enfants
    let allWa = actionsOfWp(w.id);
    let matchingActions = allWa.filter(a => {
      let actMStatus = !filtStatus || effectiveStatus(a) === filtStatus;
      let actMPerson = !filtPerson || a.people.includes(filtPerson);
      return mProj && mCdt && actMStatus && actMPerson;
    });

    // RÈGLE MÉTALLIQUE ANTI-DOUBLON
    if (matchingActions.length > 0) {
      // S'il y a des actions qui matchent, on affiche uniquement les actions (avec le nom du WP en préfixe)
      matchingActions.forEach(a => {
        items.push({
          type: 'action', 
          id: a.id, 
          title: `[${w.name}] ${a.title}`, 
          start: a.start, 
          end: a.end, 
          status: effectiveStatus(a), 
          project: p.name, 
          owner: a.people.map(u => user(u).name).join(', '), 
          pct: actionPct(a)
        });
      });
    } else if (mProj && mCdt && mStatus && mPerson) {
      // S'il n'y a AUCUNE action qui matche, mais que le WP matche, on affiche le WP seul
      items.push({
        type: 'wp', 
        id: w.id, 
        title: w.name, 
        start: w.start, 
        end: w.end, 
        status: effectiveStatus(w), 
        project: p.name, 
        owner: user(w.owner).name, 
        pct: pctWp(w.id)
      });
    }
  });
  
  let map = groupBy(items, it => it.project);
  let html = `<div style="min-width:${ganttWidth}px; position:relative;"><div class="g-head">${months()}</div><div style="position:relative;min-height:420px">${grids()}`;
  let y = 0;
  
  Object.entries(map).forEach(([projName, arr]) => {
    html += `<div class="project-header"><div class="project-title"><i class="fa-solid fa-folder"></i>${projName}</div></div>`; 
    y += 52;
    arr.forEach(it => {
      let initialsStr = it.type === 'wp' ? initials(it.owner) : initials(it.owner.split(',')[0]);
      html += `<div class="row">
        <div class="row-label"><strong>${it.title}</strong><span>${it.owner}</span></div>
        <div class="bar bar-grad-${it.status}" style="left:${xpos(it.start)}px;width:${wpx(it.start,it.end)}px;" onclick="${it.type==='wp'?`openWp('${it.id}')`:`openAction('${it.id}')`}">
          <div class="bar-progress" style="width:${it.pct}%;"></div>
          <div class="bar-content">
            ${it.title}
            <span class="mark">${initialsStr}</span>
          </div>
        </div>
      </div>`; 
      y += 64;
    });
  });
  
  if(!items.length) {
    html += `<div style="padding:80px 450px;color:var(--muted);font-weight:900;text-transform:uppercase;">Aucun élément trouvé avec ces filtres.</div>`;
  }
  
  html += `</div></div>`;
  let gt = document.getElementById('gantt'); 
  if(gt) gt.innerHTML = html;
}

