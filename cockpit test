/* --- POPUPS DE CONFIRMATION SÉCURISÉS --- */
function deleteCdt(id){
  if(!confirm('Êtes-vous sûr de vouloir supprimer définitivement ce secteur CDT ?')) return;
  if(activeProjects().some(p=>cdtIdsOfProject(p).includes(id)))return alert('Impossible : ce CDT est encore lié à au moins un projet.');
  let c = db.cdts.find(x=>x.id===id);
  db.cdts=db.cdts.filter(x=>x.id!==id);
  pushToServer('cdt_delete', {id:id}, {user:'Omar Hamzé', object:`Suppression CDT`, old:c.name, new:'-', reason:'Nettoyage'}, null, () => { save('CDT supprimé'); });
}
function editCdt(id) {
  let c = db.cdts.find(x=>x.id===id); if(!c) return;
  let nv = prompt('Modifier le nom du secteur CDT :', c.name);
  if(nv && nv.trim() && nv.trim().toUpperCase() !== c.name){
    let old = c.name; c.name = nv.trim().toUpperCase();
    pushToServer('cdt', c, {user:'Omar Hamzé', object:`Renommage CDT`, old:old, new:c.name, reason:'Renommage'}, null, () => { save('Secteur CDT modifié'); });
  }
}
function deleteUser(id) {
  if(!confirm('Êtes-vous sûr de vouloir supprimer définitivement ce membre ?')) return;
  let u = db.users.find(x=>x.id===id);
  db.users = db.users.filter(x=>x.id!==id);
  pushToServer('user_delete', {id:id}, {user:'Omar Hamzé', object:`Suppression Membre`, old:u.name, new:'-', reason:'Nettoyage'}, null, () => { save('Membre supprimé'); });
}
function archiveProject(pid){
  if(!confirm('Êtes-vous sûr de vouloir archiver ce projet ? (Ceci masquera aussi ses WPs et actions)')) return;
  let p=project(pid); if(!p)return; p.archived=true;
  db.wps.filter(w=>w.project===pid).forEach(w=>{w.archived=true;db.actions.filter(a=>a.wp===w.id).forEach(a=>a.archived=true)});
  pushToServer('project_archive', {id:pid}, {user:'Omar Hamzé', object:`Archivage Projet ${p.name}`, old:'Actif', new:'Archivé', reason:'Cascade'}, null, () => { save('Projet archivé'); });
}
function archiveWp(id){
  if(!confirm('Êtes-vous sûr de vouloir archiver / supprimer ce Work Package ? (Ses actions seront aussi supprimées)')) return;
  let w=wp(id); if(!w)return; w.archived=true; db.actions.filter(a=>a.wp===id).forEach(a=>a.archived=true);
  pushToServer('wp_archive', {id:id}, {user:'Omar Hamzé', object:`Archivage WP ${w.name}`, old:'Actif', new:'Archivé', reason:'Bouton Suppr'}, 'modalActions', () => { closeModal(); save('WP archivé'); });
}
function archiveAction(id){
  if(!confirm('Êtes-vous sûr de vouloir archiver / supprimer cette Action ?')) return;
  let a=activeActions().find(x=>x.id===id); if(!a)return; a.archived=true;
  pushToServer('action_archive', {id:id}, {user:'Omar Hamzé', object:`Archivage Action ${a.title}`, old:'Actif', new:'Archivé', reason:'Bouton Suppr'}, 'modalActions', () => { closeModal(); syncWpWithActions(a.wp); save('Action archivée'); });
