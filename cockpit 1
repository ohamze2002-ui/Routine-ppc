<div id="formModal" class="modal">
  <div class="panel form-panel">
    <div class="modal-head"><h2 id="formTitle">Formulaire</h2><button class="btn btn-white" onclick="closeForm()"><i class="fa-solid fa-xmark"></i></button></div>
    <div class="modal-body" id="formBody"></div>
  </div>
</div>
<div id="toast" class="toast"></div>

<script>
const KEY='aos_cockpit_reprise_initiale_corrigee_v1';
let db = load();
let adminOK = false;
let base = new Date();
const left = 300;
let currentPx = 10; 
let totalMonthsCount = 120; 
let ganttWidth = 3000;

function demo(){
  return {
    password:'aos',
    last:new Date().toLocaleString('fr-FR'),
    history:[],
    cdts:[{id:'c1',name:'ODYE'},{id:'c2',name:'ODYS'},{id:'c3',name:'ODYL'}],
    users:[{id:'u1',name:'Omar Hamzé',role:'AOS'},{id:'u2',name:'Cyril',role:'HO AOS'},{id:'u3',name:'Arnaud',role:'AOS leader'},{id:'u4',name:'Manu',role:'AOS agent'}],
    projects:[
      {id:'p1',name:'PPC',owner:'u2',memberIds:['u1','u2','u3'],sector:'PPC',cdtIds:['c1','c2'],priority:'Haute',archived:false},
      {id:'p2',name:'5S',owner:'u2',memberIds:['u1','u2'],sector:'5S',cdtIds:['c2','c3'],priority:'Moyenne',archived:false}
    ],
    wps:[
      {id:'w1',project:'p1',name:'WP1',owner:'u1',ownerIds:['u1'],start:'2026-06-01',end:'2026-06-20',status:'ongoing',comment:'',progress:30,modified:false,history:[],archived:false,cdtId:'c1',milestones:[]},
      {id:'w2',project:'p1',name:'WP2',owner:'u3',ownerIds:['u3'],start:'2026-07-01',end:'2026-07-31',status:'planned',comment:'',progress:0,modified:false,history:[],archived:false,cdtId:'c2',milestones:[]},
      {id:'w3',project:'p2',name:'Bureau atelier',owner:'u3',ownerIds:['u3'],start:'2026-06-01',end:'2026-06-25',status:'ongoing',comment:'',progress:40,modified:false,history:[],archived:false,cdtId:'c2',milestones:[]}
    ],
    actions:[
      {id:'a1',wp:'w1',title:'Cadrage métier',start:'2026-06-01',end:'2026-06-12',status:'ongoing',people:['u1','u2'],progress:60,comment:'',blockCause:'',history:[],archived:false,milestones:[]},
      {id:'a2',wp:'w2',title:'Validation terrain',start:'2026-07-10',end:'2026-07-24',status:'planned',people:['u3'],progress:0,comment:'',blockCause:'',history:[],archived:false,milestones:[]},
      {id:'a3',wp:'w3',title:'Audit terrain',start:'2026-06-05',end:'2026-06-18',status:'ongoing',people:['u1','u3'],progress:50,comment:'',blockCause:'',history:[],archived:false,milestones:[]}
    ]
  }
}

function load(){try{return normalizeData(JSON.parse(localStorage.getItem(KEY))||demo())}catch(e){return normalizeData(demo())}}
function normalizeData(d){
  d.password = d.password || 'aos';
  d.cdts=d.cdts||[{id:'c1',name:'ODYE'},{id:'c2',name:'ODYS'},{id:'c3',name:'ODYL'}]; d.users=d.users||[]; d.projects=d.projects||[]; d.wps=d.wps||[]; d.actions=d.actions||[]; d.history=d.history||[];
  d.projects.forEach(p=>{if(!p.cdtIds)p.cdtIds=p.cdt?[p.cdt]:(d.cdts[0]?[d.cdts[0].id]:[]);if(!p.memberIds)p.memberIds=p.owner?[p.owner]:[];p.owner=p.owner||p.memberIds[0]||'';p.archived=!!p.archived});
  d.wps.forEach(w=>{
    let p=d.projects.find(p=>p.id===w.project);
    if(!w.cdtId) w.cdtId = w.cdt || w.cdtIds?.[0] || (p && p.cdtIds ? p.cdtIds[0] : '') || (d.cdts[0] ? d.cdts[0].id : '');
    if(!w.ownerIds)w.ownerIds=w.owner?[w.owner]:[];w.owner=w.owner||w.ownerIds[0]||'';w.archived=!!w.archived;
    if(!w.milestones) w.milestones = [];
    w.milestones.forEach(m => { if(!m.status) m.status = 'planned'; });
  });
  d.actions.forEach(a=>{
      a.people=a.people||[];a.archived=!!a.archived;if(a.progress===undefined)a.progress=0;if(!a.milestones) a.milestones = [];
      a.milestones.forEach(m => { if(!m.status) m.status = 'planned'; });
  });
  return d;
}
function save(msg){db.last=new Date().toLocaleString('fr-FR');localStorage.setItem(KEY,JSON.stringify(db));renderAll();if(msg)toast(msg)}
function uid(p){return p+Date.now()+Math.random().toString(16).slice(2)}
function activeProjects(){return db.projects.filter(p=>!p.archived)}function activeWps(){let pIds=activeProjects().map(p=>p.id);return db.wps.filter(w=>!w.archived&&pIds.includes(w.project))}function activeActions(){let wIds=activeWps().map(w=>w.id);return db.actions.filter(a=>!a.archived&&wIds.includes(a.wp))}

/* SYSTÈME DE MENUS DÉROULANTS CUSTOM AVEC "SÉLECTIONNER TOUT" */
function toggleDD(id) {
  document.querySelectorAll('.dd-list').forEach(el => { if(el.id !== id) el.classList.remove('show'); });
  document.getElementById(id).classList.toggle('show');
}
window.addEventListener('click', function(e) {
  if (!e.target.closest('.dd-container')) {
    document.querySelectorAll('.dd-list').forEach(el => el.classList.remove('show'));
  }
});

function toggleAllDD(btn, listId, defaultText) {
    let list = document.getElementById(listId);
    if(!list) return;
    let cbs = list.querySelectorAll('.individual-cb');
    cbs.forEach(c => c.checked = btn.checked);
    let txtId = listId.replace('list', 'txt');
    updateDDText(listId, txtId, defaultText, true);
    if (listId === 'dd-list-people-filter') renderPeople();
}

function updateDDText(listId, textId, defaultText, isFilter = false) {
  let list = document.getElementById(listId);
  let headerTxt = document.getElementById(textId);
  if(!list || !headerTxt) return;
  
  let checkboxes = list.querySelectorAll('.individual-cb');
  let checked = list.querySelectorAll('.individual-cb:checked');
  
  let selectAllCb = list.querySelector('input:not(.individual-cb)');
  if(selectAllCb) selectAllCb.checked = (checkboxes.length > 0 && checked.length === checkboxes.length);

  if (isFilter) {
    if (checked.length === 0) headerTxt.textContent = defaultText;
    else headerTxt.textContent = defaultText + ' (' + checked.length + ')';
    if(listId.includes('road')) drawGantt(); 
    else drawGantt(); 
  } else {
    if (checked.length === 0) headerTxt.textContent = defaultText;
    else if (checked.length === 1) headerTxt.textContent = checked[0].parentNode.textContent.trim();
    else headerTxt.textContent = checked.length + ' sélectionnés';
  }
}
function getDDValues(listId) {
  let list = document.getElementById(listId);
  if(!list) return [];
  return [...list.querySelectorAll('.individual-cb:checked')].map(el => el.value);
}
function resetFilters() {
  document.querySelectorAll('.filters-wrap .dd-list input[type="checkbox"]').forEach(cb => cb.checked = false);
  document.getElementById('customStart').value = '';
  document.getElementById('customEnd').value = '';
  updateDDText('dd-list-cdt', 'dd-txt-cdt', 'Tous les secteurs CDT', true);
  updateDDText('dd-list-proj', 'dd-txt-proj', 'Tous les projets', true);
  updateDDText('dd-list-user', 'dd-txt-user', 'Membres d\'équipe', true);
  updateDDText('dd-list-stat', 'dd-txt-stat', 'Tous les statuts', true);
}

function user(id){return db.users.find(u=>u.id===id)||{name:'N/A',role:''}}function project(id){return db.projects.find(p=>p.id===id)}function wp(id){return db.wps.find(w=>w.id===id)}function cdtName(id){let c=db.cdts.find(x=>x.id===id);return c?c.name:'N/A'}function cdtNames(ids){return(ids||[]).map(cdtName).join(', ')||'N/A'}function memberNames(ids){return(ids||[]).map(id=>user(id).name).join(', ')||'N/A'}
function cdtIdsOfProject(p){return p&&p.cdtIds&&p.cdtIds.length?p.cdtIds:[]}function memberIdsOfProject(p){return p&&p.memberIds&&p.memberIds.length?p.memberIds:(p&&p.owner?[p.owner]:[])}function actionsOfWp(wid){return activeActions().filter(a=>a.wp===wid)}
function cdtIdOfWp(w){return w ? w.cdtId : ''}
function effectiveStatus(x){if(x.status==='done'||x.status==='blocked')return x.status;return x.end&&new Date(x.end+'T23:59:59')<new Date()?'late':x.status}
function escapeAttr(val) { return String(val ?? '').replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }
function stTxt(s){return{ongoing:'en cours',done:'terminé',late:'retard',planned:'à venir',blocked:'bloqué'}[s]||s}function stClass(s){return's-'+s}function fmt(d){if(!d)return'';let[y,m,day]=d.split('-');return`${day}/${m}/${y}`}
function actionPct(a){return a.progress!==undefined?parseInt(a.progress,10):0}function pctWp(wid){let acts=actionsOfWp(wid);if(!acts.length){let w=wp(wid);return w&&w.progress!==undefined?parseInt(w.progress,10):0}return Math.round(acts.reduce((s,x)=>s+actionPct(x),0)/acts.length)}function pctProject(pid){let wps=activeWps().filter(x=>x.project===pid);if(!wps.length)return 0;return Math.round(wps.reduce((a,x)=>a+pctWp(x.id),0)/wps.length)}function pctUser(uid){let acts=activeActions().filter(x=>x.people.includes(uid));if(!acts.length)return 0;return Math.round(acts.reduce((s,x)=>s+actionPct(x),0)/acts.length)}
function addHistory(object,oldVal,newVal,reason,userName='Omar Hamzé'){db.history.unshift({date:new Date().toLocaleString('fr-FR'),user:userName,object,old:oldVal,new:newVal,reason:reason||'Mise à jour'})}
function toast(t){let e=document.getElementById('toast');if(e){e.textContent=t;e.classList.add('show');setTimeout(()=>e.classList.remove('show'),2500)}}

/* GESTION ÉPURÉE DES VUES */
function showView(v){
  if(v==='admin'&&!adminOK)return askAdmin();
  document.querySelectorAll('.view').forEach(x=>x.classList.remove('active'));
  document.getElementById(v)?.classList.add('active');
  
  let navHome = document.getElementById('nav-home');
  if(v==='home'){
    if(navHome) navHome.classList.add('d-none');
  } else {
    if(navHome) navHome.classList.remove('d-none');
  }
}
function askAdmin(){let c=prompt('Code responsable (par défaut : aos) :');if(c===db.password){adminOK=true;showView('admin');toast('Accès autorisé')}else if(c!==null)alert('Code incorrect.')}
function renderAll(){lastUpdate.textContent=db.last||'-';db.wps.forEach(w=>syncWpWithActions(w.id,true));renderHome();renderProjects();renderPeople();renderAdmin();notifCount.textContent=alerts().length;if(roadModal.classList.contains('show'))drawGantt()}

function renderHome(){
  let open=activeActions().filter(a=>a.status!=='done').length;
  homeKpis.innerHTML=`<div class="home-kpi"><div class="num">${activeProjects().length}</div><div class="label">Projets actifs</div></div><div class="home-kpi"><div class="num">${db.users.length}</div><div class="label">Membres de l'équipe</div></div><div class="home-kpi"><div class="num">${open}</div><div class="label" style="${alerts().length?'color:var(--red)':''}">${alerts().length?`Actions Dont ${alerts().length} critiques`:'Actions en cours'}</div></div>`
}

function renderProjects(){
  let q=(projectSearch?.value||'').toLowerCase();
  projectsRows.innerHTML=activeProjects().filter(p=>p.name.toLowerCase().includes(q)||cdtNames(cdtIdsOfProject(p)).toLowerCase().includes(q)||user(p.owner).name.toLowerCase().includes(q)).map(p=>{
    let pc=pctProject(p.id);
    let late=activeWps().some(w=>w.project===p.id&&effectiveStatus(w)==='late');
    let blocked=activeWps().some(w=>w.project===p.id&&effectiveStatus(w)==='blocked');
    let s=pc===100?'done':blocked?'blocked':late?'late':'ongoing';
    
    let allMs = [];
    activeWps().filter(w=>w.project===p.id).forEach(w => {
       allMs.push(...(w.milestones||[]));
       activeActions().filter(a=>a.wp===w.id).forEach(a => allMs.push(...(a.milestones||[])));
    });
    let todayIso = new Date().toISOString().slice(0,10);
    let futureMs = allMs.filter(m => m.date >= todayIso).sort((a,b) => a.date.localeCompare(b.date));
    let nextMs = futureMs.length ? `<span style="color:#d97706;font-weight:800;font-size:11px;"><i class="fa-solid fa-diamond"></i> ${fmt(futureMs[0].date)}</span>` : '<span style="color:var(--muted);font-size:10px;">Aucun</span>';

    return`<tr class="row-hover" onclick="openRoadmap('project','${p.id}')"><td>${p.name}</td><td>${p.sector}</td><td><div class="cdt-chip-list">${cdtIdsOfProject(p).map(id=>`<span class="chip s-planned">${cdtName(id)}</span>`).join('')}</div></td><td><span class="chip ${stClass(s)}">${stTxt(s)}</span></td><td><div class="progress"><div class="track"><div class="fill" style="width:${pc}%;background:${s==='late'?'var(--red)':pc===100?'var(--green)':s==='blocked'?'var(--dark)':'var(--blue)'}"></div></div>${pc}%</div></td><td>${nextMs}</td><td>${user(p.owner).name}</td></tr>`
  }).join('');
}

function renderPeople(){
  let q=(peopleSearch?.value||'').toLowerCase();
  let selectedUsers = getDDValues('dd-list-people-filter');
  
  let filteredUsers = db.users.filter(u => {
      let matchSearch = u.name.toLowerCase().includes(q);
      let matchDD = selectedUsers.length === 0 || selectedUsers.includes(u.id);
      return matchSearch && matchDD;
  });

  peopleRows.innerHTML=filteredUsers.map(u=>{
    let a=activeActions().filter(x=>x.people.includes(u.id));
    let pids=[...new Set(a.map(x=>wp(x.wp)?.project).filter(Boolean))];
    let pc=pctUser(u.id);
    let late=a.some(x=>effectiveStatus(x)==='late');
    let blocked=a.some(x=>effectiveStatus(x)==='blocked');
    let s=pc===100?'done':blocked?'blocked':late?'late':'ongoing';
    
    let allMs = [];
    let userWps = activeWps().filter(w=>w.owner===u.id);
    userWps.forEach(w => allMs.push(...(w.milestones||[])));
    a.forEach(act => allMs.push(...(act.milestones||[])));
    let todayIso = new Date().toISOString().slice(0,10);
    let futureMs = allMs.filter(m => m.date >= todayIso).sort((a,b) => a.date.localeCompare(b.date));
    let nextMs = futureMs.length ? `<span style="color:#d97706;font-weight:800;font-size:11px;"><i class="fa-solid fa-diamond"></i> ${fmt(futureMs[0].date)}</span>` : '<span style="color:var(--muted);font-size:10px;">Aucun</span>';

    return`<tr class="row-hover" onclick="openRoadmap('person','${u.id}')"><td>${u.name}</td><td>${u.role}</td><td>${pids.length}</td><td>${a.filter(x=>x.status!=='done').length}</td><td><span class="chip ${stClass(s)}">${stTxt(s)}</span></td><td><div class="progress"><div class="track"><div class="fill" style="width:${pc}%;background:${s==='late'?'var(--red)':pc===100?'var(--green)':s==='blocked'?'var(--dark)':'var(--blue)'}"></div></div>${pc}%</div></td><td>${nextMs}</td></tr>`
  }).join('');
}

function renderAdmin(){
  apOwner.innerHTML=db.users.map(u=>`<option value="${u.id}">${u.name}</option>`).join('');
  let ddCdt = document.getElementById('dd-ap-cdt');
  if(ddCdt) {
    ddCdt.innerHTML = `<label class="dd-item" style="border-bottom:1px solid var(--line); margin-bottom:4px; padding-bottom:6px;"><input type="checkbox" onchange="toggleAllDD(this, 'dd-ap-cdt', 'Sélectionner CDT...')"> <i>Tout sélectionner</i></label>` + db.cdts.map(c=>`<label class="dd-item"><input type="checkbox" value="${c.id}" class="individual-cb" onchange="updateDDText('dd-ap-cdt', 'txt-ap-cdt', 'Sélectionner CDT...', false)"> ${c.name}</label>`).join('');
  }
  
  let ddPeopleFilt = document.getElementById('dd-list-people-filter');
  if(ddPeopleFilt) {
      let checkedP = getDDValues('dd-list-people-filter');
      let htmlP = `<label class="dd-item" style="border-bottom:1px solid var(--line); margin-bottom:4px; padding-bottom:6px;"><input type="checkbox" onchange="toggleAllDD(this, 'dd-list-people-filter', 'Tous les membres');"> <i>Tout sélectionner</i></label>`;
      htmlP += db.users.map(u=>`<label class="dd-item"><input type="checkbox" value="${u.id}" class="individual-cb" ${checkedP.includes(u.id)?'checked':''} onchange="updateDDText('dd-list-people-filter', 'dd-txt-people-filter', 'Tous les membres', false); renderPeople();"> ${u.name}</label>`).join('');
      ddPeopleFilt.innerHTML = htmlP;
      updateDDText('dd-list-people-filter', 'dd-txt-people-filter', 'Tous les membres', false);
  }

  adminProjects.innerHTML=activeProjects().map(p=>`<div class="mini"><div class="mini-info"><b>${p.name}</b><br><span style="color:var(--muted);font-size:11px">${cdtNames(cdtIdsOfProject(p))} · Responsable : ${user(p.owner).name}</span></div><div class="actions-mini"><button class="btn btn-white" style="font-size:10px;padding:6px 10px;" onclick="openProjectForm('${p.id}')">Modifier</button><button class="btn btn-red" style="font-size:10px;padding:6px 10px;" onclick="archiveProject('${p.id}')">Archiver</button></div></div>`).join('');
