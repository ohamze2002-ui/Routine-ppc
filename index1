        function renderMaturityBars(maturity, type) {
            const labels = type === 'daily' ? { avanceRetard: 'Avance / retard', aleas: 'Aléas', decision: 'Décision' } : { performance: 'Performance', paretoAleas: 'Pareto aléas', planAction: 'Plan d’action' };
            const obj = maturity?.[type] || {};
            return Object.keys(labels).map(k => {
                const v = obj[k] ?? 0;
                return `<div class="flex flex-col gap-1"><div class="flex items-center justify-between text-[11px] font-semibold text-slate-600"><span>${labels[k]}</span><span>${v}%</span></div><div class="bar-track"><div class="bar-fill ${scoreColor(v)}" style="width:${v}%"></div></div></div>`;
            }).join('');
        }

        function normalizeActionStatus(status) {
            const s = String(status || '').toLowerCase();
            if (s.includes('fait') || s.includes('done') || s.includes('termin')) return 'done';
            if (s.includes('cours') || s.includes('ongoing') || s.includes('progress')) return 'ongoing';
            return 'not_started';
        }

        function getActionStatusMeta(status) {
            const s = normalizeActionStatus(status);
            if (s === 'done') return { label: 'Fait', icon: 'fa-circle-check', cls: 'text-emerald-600' };
            if (s === 'ongoing') return { label: 'En cours', icon: 'fa-circle-half-stroke', cls: 'text-amber-500' };
            return { label: 'Non commencé', icon: 'fa-circle-xmark', cls: 'text-slate-400' };
        }

        function nextActionStatus(status) {
            const s = normalizeActionStatus(status); return s === 'not_started' ? 'ongoing' : (s === 'ongoing' ? 'done' : 'not_started');
        }

        function renderActions(actions, side, key, routineType) {
            if (!actions || actions.length === 0) return `<div class="action-card border-dashed border-slate-200 bg-slate-50/50"><div class="flex items-center gap-1.5 text-slate-400 font-extrabold text-[10px] uppercase tracking-wider"><i class="fa-solid fa-list-ol"></i> Actions</div><p class="text-[11px] text-slate-400 italic mt-1">Aucune action définie</p></div>`;
            return `
                <div class="action-card">
                    <div class="flex items-center justify-between mb-1"><div class="flex items-center gap-1.5 text-blue-700 font-extrabold text-[10px] uppercase tracking-wider"><i class="fa-solid fa-list-ol"></i> Actions</div></div>
                    ${actions.map((a, idx) => { const meta = getActionStatusMeta(a.status); return `<div class="action-row"><i class="fa-solid ${meta.icon} ${meta.cls} action-status-btn"></i><span class="action-top-badge">Top ${idx + 1}</span><div class="action-text"><span class="action-criteria">${a.criteria || 'Critère'}</span><span class="text-slate-400 mx-1">—</span><span>${a.action || ''}</span></div></div>`; }).join('')}
                </div>
            `;
        }

        function getLeafChildren(groupKey) {
            const node = db[groupKey]; if (!node?.children) return [];
            let res = []; node.children.forEach(ck => { const child = db[ck]; if (child) { if (child.isGroup && child.children) res = res.concat(getLeafChildren(ck)); else res.push(ck); } }); return res;
        }

        function getHeatmapRows(groupKey) {
            const node = db[groupKey]; if (!node?.children) return [];
            return groupKey === 'ody' ? node.children.filter(k => db[k]) : getLeafChildren(groupKey);
        }

        function heatCell(value) {
            let cls = value >= 75 ? "bg-emerald-50 text-emerald-700 border-emerald-100" : (value >= 55 ? "bg-blue-50 text-blue-700 border-blue-100" : (value >= 35 ? "bg-amber-50 text-amber-700 border-amber-100" : "bg-rose-50 text-rose-700 border-rose-100"));
            return `<td class="px-3 py-2 text-center border ${cls} font-extrabold text-xs">${value}%</td>`;
        }

        function renderGroupHeatmap(groupKey) {
            const rows = getHeatmapRows(groupKey); if (!rows.length) return "";
            return `
                <div class="bg-white rounded-xl p-5 border border-slate-200 shadow-sm flex flex-col gap-4">
                    <h3 class="font-bold text-slate-800 text-sm uppercase flex items-center gap-2"><i class="fa-solid fa-table-cells-large text-blue-600"></i>Heatmap maturité</h3>
                    <div class="overflow-x-auto">
                        <table class="w-full border-collapse text-xs">
                            <thead><tr class="text-slate-500 uppercase text-[10px] tracking-wider bg-slate-50"><th class="text-left px-3 py-2 border border-slate-100">Élément</th><th class="text-center px-3 py-2 border border-slate-100">Daily</th><th class="text-center px-3 py-2 border border-slate-100">Weekly</th><th class="text-center px-3 py-2 border border-slate-100">Global</th></tr></thead>
                            <tbody>${rows.map(rk => { const r = db[rk]; return `<tr><td class="px-3 py-2 border border-slate-100 font-bold text-slate-700 bg-white">${r.name}</td>${heatCell(getRoutineScore(r.maturity, 'daily'))}${heatCell(getRoutineScore(r.maturity, 'weekly'))}${heatCell(getOverallScore(r.maturity))}</tr>`; }).join('')}</tbody>
                        </table>
                    </div>
                </div>
            `;
        }

        function renderGroupActions(groupKey) {
            const sectors = getLeafChildren(groupKey); const actions = [];
            sectors.forEach(sk => {
                const s = db[sk]; if (!s) return;
                ['daily', 'weekly'].forEach(type => { (s.actions?.[type] || []).forEach(act => { if (normalizeActionStatus(act.status) !== 'done') { actions.push({ sector: s.name, type: type === 'daily' ? 'Daily' : 'Weekly', criteria: act.criteria, action: act.action, status: act.status }); } }); });
            });
            return `
                <div class="bg-white rounded-xl p-5 border border-slate-200 shadow-sm flex flex-col gap-4">
