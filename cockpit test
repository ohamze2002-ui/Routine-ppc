  let rows = alerts().map(x => {
    let isAct = !!x.title;
    let w = isAct ? wp(x.wp) : x; 
    let p = w ? project(w.project) : null;
    let cdt = w ? cdtName(w.cdtId) : '';
    let st = effectiveStatus(x);
    let cause = (st === 'blocked' && x.blockCause) ? `<div class="alert-cause"><b>Cause du blocage :</b> ${escapeAttr(x.blockCause)}</div>` : '';
    let persons = isAct ? memberNames(x.people) : user(w.owner).name;
    let context = isAct ? `${p?.name} > ${w?.name}` : `${p?.name}`;
    let icon = isAct ? `<i class="fa-solid fa-angle-right" style="color:var(--orange)"></i> Action` : `<i class="fa-solid fa-layer-group" style="color:var(--blue)"></i> WP`;
    
