function closeRoadmap(){roadModal.classList.remove('show')}

function drawGantt(){
  autoComputeTimeBounds(); 

  let filtCdts = getDDValues('dd-list-cdt');
  let filtProjs = getDDValues('dd-list-proj');
  let filtPersons = getDDValues('dd-list-user');
  let filtStatuses = getDDValues('dd-list-stat');

  let titleParts = [];
  let titleIcon = "fa-route";
  
  if (filtPersons.length === 1) { titleParts.push(user(filtPersons[0]).name); titleIcon = "fa-user-check"; }
  else if (filtPersons.length > 1) { titleParts.push(`Équipe (${filtPersons.length})`); titleIcon = "fa-users"; }

  if (filtProjs.length === 1) { titleParts.push(project(filtProjs[0])?.name); if(!filtPersons.length) titleIcon = "fa-folder"; }
  else if (filtProjs.length > 1) { titleParts.push(`Projets (${filtProjs.length})`); }

  if (filtCdts.length === 1) { titleParts.push(cdtName(filtCdts[0])); if(!filtPersons.length && !filtProjs.length) titleIcon = "fa-industry"; }
  else if (filtCdts.length > 1) { titleParts.push(`Secteurs (${filtCdts.length})`); }

  let titleEl = document.getElementById('roadTitle');
  if (titleParts.length > 0) {
      titleEl.innerHTML = `<i class="fa-solid ${titleIcon}" style="color:var(--blue);margin-right:8px;"></i> Roadmap : ${titleParts.join(' · ')}`;
  } else {
      titleEl.innerHTML = `Roadmap Transverse Unique`;
  }

  let html=`<div style="min-width:${ganttWidth}px;position:relative;"><div class="g-head">${months()}</div><div class="gantt-inner">${grids()}`;
  let has=false;

  db.cdts.forEach(c => {
    if(filtCdts.length && !filtCdts.includes(c.id)) return;
    
    let cdtWps = activeWps().filter(w => w.cdtId === c.id);
    if(filtProjs.length) cdtWps = cdtWps.filter(w => filtProjs.includes(w.project));
    
    if(filtPersons.length) {
      cdtWps = cdtWps.filter(w => 
        filtPersons.includes(w.owner) || 
        activeActions().some(a => a.wp === w.id && a.people.some(p => filtPersons.includes(p)))
      );
    }

    if(!cdtWps.length) return;

    html+=`<div class="cdt-header"><div class="cdt-title"><i class="fa-solid fa-industry"></i>${c.name}</div></div>`;
    
    let projsInCdt = [...new Set(cdtWps.map(w => w.project))];
    projsInCdt.forEach(pid => {
      let p = project(pid); if(!p) return;
      let pWps = cdtWps.filter(w => w.project === pid);

      pWps.sort((a, b) => new Date(a.start) - new Date(b.start));

      html+=`<div class="project-header"><div class="project-title"><i class="fa-solid fa-folder"></i>Projet : ${p.name}</div></div>`;
      
      pWps.forEach(w => {
        let wpStatusMatch = filtStatuses.length ? filtStatuses.includes(effectiveStatus(w)) : true;
        let shouldRenderWp = wpStatusMatch;
        
        if(filtPersons.length) {
          shouldRenderWp = (filtPersons.includes(w.owner) && wpStatusMatch) || 
                           activeActions().some(a => a.wp === w.id && a.people.some(p => filtPersons.includes(p)));
        }

        if(shouldRenderWp) {
          let renderWp = renderGanttRow({
            type: 'wp', id: w.id, title: w.name, cleanTitle: w.name, start: w.start, end: w.end,
            status: effectiveStatus(w), owner: user(w.owner).name, pct: pctWp(w.id), milestones: w.milestones, isActionUI: false
          });
          if (renderWp) { has = true; html += renderWp; }
        }

        let wActions = activeActions().filter(a => a.wp === w.id);
        if(filtPersons.length) wActions = wActions.filter(a => a.people.some(p => filtPersons.includes(p)));
        if(filtStatuses.length) wActions = wActions.filter(a => filtStatuses.includes(effectiveStatus(a)));

        wActions.sort((a, b) => new Date(a.start) - new Date(b.start));

        wActions.forEach(a => {
          let renderAct = renderGanttRow({
            type: 'action', id: a.id, title: `&nbsp;&nbsp;<i class="fa-solid fa-angle-right" style="opacity:0.5; margin-right:4px;"></i> ${a.title}`, cleanTitle: a.title, start: a.start, end: a.end,
            status: effectiveStatus(a), owner: a.people.map(u=>user(u).name).join(', '), pct: actionPct(a), milestones: a.milestones, isActionUI: true
          });
          if (renderAct) { has = true; html += renderAct; }
        });
      });
    });
  });

  if(!has) html+=`<div style="padding:80px 450px;color:var(--muted);font-weight:900;text-transform:uppercase;font-size:14px;">Aucun élément trouvé avec ces filtres.</div>`;
  
  html += `<div class="row" style="height:150px; border:none; background:transparent;"><div class="row-label" style="height:100%; border-bottom:none;"></div></div>`;
  
  html+=`</div></div>`;
  gantt.innerHTML=html;
}

function renderGanttRow(it) {
  let cStart = document.getElementById('customStart')?.value;
  let cEnd = document.getElementById('customEnd')?.value;

  let dStart = new Date(it.start);
  let dEnd = new Date(it.end);

  if (cStart && cEnd) {
      let fS = new Date(cStart);
      let fE = new Date(cEnd);
      if (dEnd < fS || dStart > fE) return ''; 
      if (dStart < fS) dStart = fS; 
      if (dEnd > fE) dEnd = fE; 
  }

  let ini = initials(it.owner.split(',')[0]);
  let rowCls = it.isActionUI ? "wp-row-ui action-row-ui" : "wp-row-ui";
  let barCls = it.isActionUI ? `bar bar-grad-${it.status} action-bar-ui` : `bar bar-grad-${it.status}`;
  
  let bX = xpos(dStart);
  let bW = Math.max(1, wpx(dStart, dEnd)); 

  // LE TEXTE S'ADAPTE EXACTEMENT AU ZOOM, MAIS RESTE A L'INTERIEUR TANT QUE LA BARRE FAIT > 180px
  let scale = Math.min(1, currentPx / 10);
  let fzBar = Math.max(6, Math.round(11 * scale));
  let fzMark = Math.max(5, Math.round(9 * scale));
  let fzDiamond = Math.max(12, Math.round(22 * scale));
  let topDiamond = Math.max(-4, Math.round(-8 * scale));
  
  let padMark = `${Math.max(1, Math.round(2*scale))}px ${Math.max(2, Math.round(6*scale))}px`;
  let gapIn = Math.max(2, Math.round(4*scale));

  // LIMITE STRICTE A 180PX
  let isShort = bW < 180; 

  let contentIn = isShort ? '' : `
    <div style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap; margin-right:${gapIn}px; text-align:left; flex:1; font-size:${fzBar}px;">${it.cleanTitle}</div>
    <div style="display:flex; gap:${gapIn}px; flex-shrink:0; align-items:center;">
      <span class="mark" style="font-size:${fzMark}px; padding:${padMark}; line-height:1;">${it.pct}%</span>
      <span class="mark" style="font-size:${fzMark}px; padding:${padMark}; line-height:1;">${ini}</span>
    </div>`;

  let outTitle = it.isActionUI ? `<i class="fa-solid fa-angle-right" style="opacity:0.6;margin-right:3px;"></i>${it.cleanTitle}` : it.cleanTitle;
  
  let contentOut = isShort ? `
    <span style="font-weight:800;color:var(--text);font-size:10px;">${outTitle}</span>
    <span style="background:#e2e8f0;color:#334155;padding:2px 4px;border-radius:3px;font-size:9px;font-weight:900;">${it.pct}%</span>
    <span style="background:#e2e8f0;color:#334155;padding:2px 4px;border-radius:3px;font-size:9px;font-weight:900;">${ini}</span>` : '';

  let htmlRow = `<div class="${rowCls}"><div class="row-label"><strong>${it.title}</strong><span>${it.owner}</span></div>`;
  
  htmlRow += `<div class="${barCls}" style="left:${bX}px;width:${bW}px;" onclick="${it.type==='wp'?`openWp('${it.id}')`:`openAction('${it.id}')`}">
                <div class="bar-progress" style="width:${it.pct}%;"></div>
                <div class="bar-content" style="padding:0 ${Math.max(2, 8*scale)}px; justify-content:space-between;">${contentIn}</div>
              </div>`;

  if(isShort) {
      let tPos = it.isActionUI ? '6px' : '8px';
      htmlRow += `<div style="position:absolute; left:${bX + bW + 6}px; top:${tPos}; display:flex; gap:4px; align-items:center; z-index:15; pointer-events:none; white-space:nowrap; text-shadow: 1px 1px 2px #fff, -1px -1px 2px #fff, 1px -1px 2px #fff, -1px 1px 2px #fff;">${contentOut}</div>`;
  }

  if(it.milestones && it.milestones.length) {
    it.milestones.forEach(m => {
      let md = new Date(m.date);
      if (cStart && cEnd) {
          let fS = new Date(cStart), fE = new Date(cEnd);
          if (md < fS || md > fE) return; 
      }
      let mx = xpos(m.date);
      let msColor = m.status === 'done' ? '#16a34a' : 'var(--orange)';
      htmlRow += `<div class="milestone-diamond" style="left:${mx}px; color:${msColor}; font-size:${fzDiamond}px; top:${topDiamond}px;" title="JALON : ${escapeAttr(m.name)} (${fmt(m.date)}) - ${m.status==='done'?'Terminé':'À venir'}">♦</div>`;
    });
  }
  
  htmlRow += `</div>`;
  return htmlRow;
}

