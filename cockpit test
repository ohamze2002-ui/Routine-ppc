    if(navHome) navHome.classList.add('d-none');
  } else {
    if(navHome) navHome.classList.remove('d-none');
  }
}
function askAdmin(){let c=prompt('Code responsable (par défaut : aos) :');if(c===db.password){adminOK=true;showView('admin');toast('Accès autorisé')}else if(c!==null)alert('Code incorrect.')}
function renderAll(){
  if(!db) return; 
  let lu = document.getElementById('lastUpdate');
