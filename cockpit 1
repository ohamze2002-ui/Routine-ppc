<div id="toast" class="toast"></div>

<script>
const KEY='aos_cockpit_master_final_1';
let db = load();
let adminOK = false;

// Variables globales Gantt
let base = new Date();
const left = 280; 
const px = 10;
let totalMonthsCount = 120;
let ganttWidth = 3000;
let roadMode = 'projects';

function demo(){
  return {
    password:'aos',
    last:new Date().toLocaleString('fr-FR'),
    history:[],
    cdts:[
      {id:'c1', name:'CDT Mât'},
      {id:'c2', name:'CDT Nacelle'},
      {id:'c3', name:'Transverse'}
    ],
    users:[
      {id:'u1',name:'Omar Hamzé',role:'AOS'},
      {id:'u2',name:'Lucas Martin',role:'AOS'},
      {id:'u3',name:'Sarah Moreau',role:'AOS'},
      {id:'u4',name:'Cyril',role:'Manager'}
    ],
    projects:[
      {id:'p1',name:'AOS Cockpit',owner:'u1',sector:'AOS',cdt:'c3',priority:'Haute',archived:false},
      {id:'p2',name:'PPC Saint-Éloi',owner:'u2',sector:'PPC',cdt:'c1',priority:'Moyenne',archived:false}
    ],
    wps:[
      {id:'w1',project:'p1',name:'Cadrage du besoin',owner:'u1',cdt:'c1',start:'2026-06-01',end:'2026-06-15',status:'done',comment:'',progress:100,modified:false,history:[],archived:false},
      {id:'w2',project:'p1',name:'Maquette visuelle',owner:'u1',cdt:'c2',start:'2026-06-16',end:'2026-06-30',status:'ongoing',comment:'',progress:40,modified:false,history:[],archived:false},
      {id:'w3',project:'p2',name:'Déploiement routines',owner:'u2',cdt:'c1',start:'2026-07-01',end:'2026-07-20',status:'planned',comment:'',progress:0,modified:false,history:[],archived:false}
    ],
    actions:[
      {id:'a1',wp:'w1',title:'Réunion d\'équipe',start:'2026-06-01',end:'2026-06-05',status:'done',people:['u1'],progress:100,comment:'',blockCause:'',history:[],archived:false},
      {id:'a2',wp:'w2',title:'Design Figma',start:'2026-06-16',end:'2026-06-25',status:'ongoing',people:['u1','u3'],progress:40,comment:'',blockCause:'',history:[],archived:false}
    ]
  }
}

// ----------------------------------------------------
// GESTION DES DONNEES (LOAD / SAVE / FILTRES)
// ----------------------------------------------------
function load(){
  try {
    let d = JSON.parse(localStorage.getItem(KEY)); 
    if(d && !d.cdts) d.cdts=[{id:'c1', name:'CDT Mât'},{id:'c2', name:'CDT Nacelle'},{id:'c3', name:'Transverse'}]; 
    return d || demo();
  } catch(e) { return demo(); }
}

function save(msg){ 
  db.last = new Date().toLocaleString('fr-FR'); 
  localStorage.setItem(KEY, JSON.stringify(db)); 
  renderAll(); 
  if(msg) toast(msg); 
}

function uid(p){ return p + Date.now() + Math.random().toString(16).slice(2); }

function activeProjects(){ return db.projects.filter(p => !p.archived); }
function activeWps(){ 
  let pIds = activeProjects().map(p => p.id);
  return db.wps.filter(w => !w.archived && pIds.includes(w.project)); 
}
function activeActions(){ 
  let wIds = activeWps().map(w => w.id);
  return db.actions.filter(a => !a.archived && wIds.includes(a.wp)); 
}

function user(id){ return db.users.find(u => u.id === id) || {name:'N/A', role:''}; }
function project(id){ return db.projects.find(p => p.id === id); }
function wp(id){ return db.wps.find(w => w.id === id); }
function cdtName(id){ let c = db.cdts.find(x => x.id === id); return c ? c.name : 'Transverse'; }
function actionsOfWp(wid){ return activeActions().filter(a => a.wp === wid); }

function effectiveStatus(x){
  if(x.status === 'done' || x.status === 'blocked') return x.status;
  return x.end && new Date(x.end+'T23:59:59') < new Date() ? 'late' : x.status;
}
function stTxt(s){ return {ongoing:'en cours', done:'terminé', late:'retard', planned:'à venir', blocked:'bloqué'}[s] || s; }
function stClass(s){ return 's-' + s; }
function fmt(d){ if(!d) return ''; let [y,m,day] = d.split('-'); return `${day}/${m}/${y}`; }

// ----------------------------------------------------
// CALCUL DE L'AVANCEMENT
// ----------------------------------------------------
function actionPct(a) { return a.progress !== undefined ? parseInt(a.progress, 10) : 0; }
function pctWp(wid){
  let acts = actionsOfWp(wid);
  if(acts.length === 0) { 
    let w = wp(wid); 
    return w && w.progress !== undefined ? parseInt(w.progress, 10) : 0; 
  }
  return Math.round(acts.reduce((s, x) => s + actionPct(x), 0) / acts.length);
}
function pctProject(pid){
  let wps = activeWps().filter(x => x.project === pid);
  if(!wps.length) return 0;
  return Math.round(wps.reduce((a,x) => a + pctWp(x.id), 0) / wps.length);
}
function pctUser(uid){
  let acts = activeActions().filter(x => x.people.includes(uid));
  if(!acts.length) return 0;
  return Math.round(acts.reduce((s, x) => s + actionPct(x), 0) / acts.length);
}

// ----------------------------------------------------
// SYNCHRONISATION WP -> STATUT (SANS TOUCHER LES DATES)
// ----------------------------------------------------
function syncWpWithActions(wid, silent = false){
  let w = wp(wid); 
  if(!w) return;
  let acts = actionsOfWp(wid);
  
  if (acts.length > 0) {
    let allDone = acts.every(a => a.status === 'done' || actionPct(a) === 100);
    let anyBlocked = acts.some(a => a.status === 'blocked');
    let anyLate = acts.some(a => effectiveStatus(a) === 'late');
    
    let newStatus = w.status;
    if (allDone) newStatus = 'done';
    else if (anyBlocked) newStatus = 'blocked';
    else if (anyLate) newStatus = 'late';
    else newStatus = 'ongoing';
    
    if (w.status !== newStatus) {
      if(!silent) w.history.push(`${new Date().toLocaleString('fr-FR')} · Statut auto-ajusté par les actions : ${stTxt(w.status)} → ${stTxt(newStatus)}`);
      w.status = newStatus;
    }
  } else {
    // S'il n'a plus d'action et qu'il était en terminé automatique, on le remet en cours par securite
    if(w.status === 'done') w.status = 'ongoing';
  }
}

function addHistory(object, oldVal, newVal, reason, userName = 'Omar Hamzé'){
  db.history.unshift({date: new Date().toLocaleString('fr-FR'), user: userName, object, old: oldVal, new: newVal, reason: reason || "Mise à jour"});
}

function toast(t){
  let e = document.getElementById('toast');
  if(e){ e.textContent = t; e.classList.add('show'); setTimeout(() => e.classList.remove('show'), 2500); }
}

// ----------------------------------------------------
// GESTION DES VUES (ROUTAGE)
// ----------------------------------------------------
function showView(v){
  if(v === 'admin' && !adminOK) return askAdmin();
  
  // Bascule les sections
  document.querySelectorAll('.view').forEach(x => x.classList.remove('active'));
  let targetView = document.getElementById(v);
  if(targetView) targetView.classList.add('active');
  
  // Masque tous les liens du Header par sécurité
  let allNavs = ['nav-home', 'nav-projects', 'nav-people', 'nav-admin'];
  allNavs.forEach(id => {
    let el = document.getElementById(id);
    if(el) el.classList.add('d-none');
  });
  
  // Masque les outils sur l'accueil
  let tools = ['btnNotif', 'btnHist', 'btnGuide'];
  
  if (v === 'home') {
    tools.forEach(id => { let el = document.getElementById(id); if(el) el.classList.add('d-none'); });
  } else {
    tools.forEach(id => { let el = document.getElementById(id); if(el) el.classList.remove('d-none'); });
    
    // Réaffiche les liens sauf celui de la page active
    allNavs.forEach(id => {
      let el = document.getElementById(id);
      if(el) el.classList.remove('d-none');
    });
    let activeNav = document.getElementById('nav-' + v);
    if(activeNav) activeNav.classList.add('d-none');
  }
}

function askAdmin(){
  let c = prompt('Code responsable :');
  if (c === db.password) { adminOK = true; showView('admin'); toast('Accès autorisé'); } 
  else if (c !== null) { alert('Code incorrect.'); }
}

// ----------------------------------------------------
// RENDUS DES DONNEES (TABLEAUX)
// ----------------------------------------------------
function renderAll(){
  let lu = document.getElementById('lastUpdate'); 
  if(lu) lu.textContent = db.last || '-';
  
  // Force synchro des statuts
  db.wps.forEach(w => syncWpWithActions(w.id, true));

  renderHome();
  renderProjects();
  renderPeople();
  renderAdmin();
  
  let nc = document.getElementById('notifCount'); 
  if(nc) nc.textContent = alerts().length;
  
  let rm = document.getElementById('roadModal');
  if(rm && rm.classList.contains('show')) renderRoadmap(); // Refresh du Gantt si ouvert
}

function renderHome(){
  let open = activeActions().filter(a => a.status !== 'done').length;
  let hk = document.getElementById('homeKpis'); 
  if(hk) {
    hk.innerHTML = `
      <div class="home-kpi"><div class="num">${activeProjects().length}</div><div class="label">Projets actifs</div></div>
      <div class="home-kpi"><div class="num">${db.users.length}</div><div class="label">Membres de l'équipe</div></div>
      <div class="home-kpi"><div class="num">${open}</div><div class="label" style="${alerts().length>0 ? 'color:var(--red)' : ''}">${alerts().length>0 ? `Dont ${alerts().length} critiques` : 'Actions en cours'}</div></div>
    `;
  }
}

function renderProjects(){
  let q = (document.getElementById('projectSearch')?.value || '').toLowerCase();
  let pr = document.getElementById('projectsRows'); 
  if(pr) {
    pr.innerHTML = activeProjects()
      .filter(p => p.name.toLowerCase().includes(q) || cdtName(p.cdt).toLowerCase().includes(q))
      .map(p => {
        let pc = pctProject(p.id);
        let late = activeWps().some(w => w.project === p.id && effectiveStatus(w) === 'late');
        let blocked = activeWps().some(w => w.project === p.id && effectiveStatus(w) === 'blocked');
        let s = pc === 100 ? 'done' : blocked ? 'blocked' : late ? 'late' : 'ongoing';
        
        return `<tr class="row-hover" onclick="openRoadmap('project', '${p.id}')">
          <td>${p.name}</td><td>${p.sector}</td><td><span class="chip s-planned">${cdtName(p.cdt)}</span></td>
          <td><span class="chip ${stClass(s)}">${stTxt(s)}</span></td>
          <td><div class="progress"><div class="track"><div class="fill" style="width:${pc}%;background:${s==='late'?'var(--red)':pc===100?'var(--green)':s==='blocked'?'var(--dark)':'var(--blue)'}"></div></div>${pc}%</div></td>
          <td>${user(p.owner).name}</td>
        </tr>`;
      }).join('');
  }
}

function renderPeople(){
  let q = (document.getElementById('peopleSearch')?.value || '').toLowerCase();
  let pr = document.getElementById('peopleRows'); 
  if(pr) {
    pr.innerHTML = db.users
      .filter(u => u.name.toLowerCase().includes(q))
      .map(u => {
        let a = activeActions().filter(x => x.people.includes(u.id));
        let pids = [...new Set(a.map(x => wp(x.wp)?.project).filter(Boolean))];
        let pc = pctUser(u.id);
        let late = a.some(x => effectiveStatus(x) === 'late');
        let blocked = a.some(x => effectiveStatus(x) === 'blocked');
        let s = pc === 100 ? 'done' : blocked ? 'blocked' : late ? 'late' : 'ongoing';
        
        return `<tr class="row-hover" onclick="openRoadmap('person', '${u.id}')">
          <td>${u.name}</td><td>${u.role}</td><td>${pids.length}</td><td>${a.filter(x => x.status !== 'done').length}</td>
          <td><span class="chip ${stClass(s)}">${stTxt(s)}</span></td>
          <td><div class="progress"><div class="track"><div class="fill" style="width:${pc}%;background:${s==='late'?'var(--red)':pc===100?'var(--green)':s==='blocked'?'var(--dark)':'var(--blue)'}"></div></div>${pc}%</div></td>
        </tr>`;
      }).join('');
  }
}

// ----------------------------------------------------
// ADMINISTRATION (SANS CRASH)
// ----------------------------------------------------
function renderAdmin(){
  let apo = document.getElementById('apOwner');
  if(apo) apo.innerHTML = db.users.map(u => `<option value="${u.id}">${u.name}</option>`).join('');
  
  let apc = document.getElementById('apCdt');
  if(apc) apc.innerHTML = db.cdts.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
  
  let ap = document.getElementById('adminProjects');
  if(ap) {
    ap.innerHTML = activeProjects().map(p => `
      <div class="mini">
        <div><b>${p.name}</b><br><span style="color:var(--muted);font-size:11px">${cdtName(p.cdt)} · ${user(p.owner).name}</span></div>
        <div class="actions">
          <button class="btn btn-white" style="font-size:10px; padding:6px 10px;" onclick="openProjectForm('${p.id}')">Modifier</button>
          <button class="btn btn-red" style="font-size:10px; padding:6px 10px;" onclick="archiveProject('${p.id}')">Archiver</button>
        </div>
      </div>`).join('');
  }
  
  let au = document.getElementById('adminUsers');
  if(au) {
    au.innerHTML = db.users.map(u => `
      <div class="mini">
        <div><b>${u.name}</b><br><span style="color:var(--muted);font-size:11px">${u.role}</span></div>
        <button class="btn btn-white" style="font-size:10px; padding:6px 10px;" onclick="openUserForm('${u.id}')">Modifier</button>
      </div>`).join('');
  }
  
  let ac = document.getElementById('adminCdts');
  if(ac) {
    ac.innerHTML = db.cdts.map(c => `
      <div class="mini">
        <div><b>${c.name}</b></div>
        <button class="btn btn-red" style="font-size:10px; padding:6px 10px;" onclick="deleteCdt('${c.id}')">Suppr</button>
      </div>`).join('');
  }
}

function addProject(){
  let nameEl = document.getElementById('apName'); let an = nameEl ? nameEl.value.trim() : '';
  let ownerEl = document.getElementById('apOwner'); let ao = ownerEl ? ownerEl.value : '';
  let sectorEl = document.getElementById('apSector'); let ase = sectorEl ? sectorEl.value.toUpperCase() : 'AOS';
  let cdtEl = document.getElementById('apCdt'); let acdt = cdtEl ? cdtEl.value : '';
  let prioEl = document.getElementById('apPriority'); let apri = prioEl ? prioEl.value : 'Moyenne';
  
  if(!an) return toast('Nom projet obligatoire');
  db.projects.push({id:uid('p'), name:an, owner:ao, sector:ase, cdt:acdt, priority:apri, archived:false});
  
  if(nameEl) nameEl.value = ''; 
  if(sectorEl) sectorEl.value = ''; 
  
  addHistory(`Projet "${an}"`,'-','Création','Création depuis Administration');
  save('Projet créé');
}

function addUser(){
  let nameEl = document.getElementById('auName'); let aun = nameEl ? nameEl.value.trim() : '';
  let roleEl = document.getElementById('auRole'); let aur = roleEl ? roleEl.value : 'AOS';
  
  if(!aun) return toast('Nom manquant');
  db.users.push({id:uid('u'), name:aun, role:aur}); 
  
  if(nameEl) nameEl.value = ''; 
  if(roleEl) roleEl.value = ''; 
  
  addHistory(`Utilisateur "${aun}"`,'-','Création','Création depuis Administration');
  save('Membre ajouté');
}

function addCdt(){
  let nameEl = document.getElementById('acName'); let cn = nameEl ? nameEl.value.trim() : '';
  if(!cn) return toast('Nom du CDT requis');
  db.cdts.push({id:uid('c'), name:cn}); 
  if(nameEl) nameEl.value = ''; 
  save('Secteur CDT ajouté');
}

function deleteCdt(id){ 
  db.cdts = db.cdts.filter(x => x.id !== id); 
  save('CDT supprimé'); 
}

// ----------------------------------------------------
// ARCHIVAGE EN CASCADE
// ----------------------------------------------------
function archiveProject(pid){ 
  let p = project(pid); 
  if(!p) return;
  p.archived = true; 
  db.wps.filter(w => w.project === pid).forEach(w => { 
    w.archived = true; 
    db.actions.filter(a => a.wp === w.id).forEach(a => a.archived = true); 
  });
  addHistory(`Projet "${p.name}"`, 'Actif', 'Archivé', 'Archivage en cascade'); 
  save('Projet archivé'); 
}

function archiveWp(id){ 
  let w = wp(id); 
  if(!w) return;
  w.archived = true; 
  db.actions.filter(a => a.wp === id).forEach(a => a.archived = true); 
  addHistory(`WP "${w.name}"`, 'Actif', 'Archivé', 'Archivage en cascade'); 
  closeModal(); 
  save('WP archivé'); 
}

function archiveAction(id){ 
  let a = activeActions().find(x => x.id === id); 
  if(!a) return;
  a.archived = true; 
  addHistory(`Action "${a.title}"`, 'Actif', 'Archivé', 'Archivage Action'); 
  closeModal(); 
  syncWpWithActions(a.wp); 
  save('Action archivée'); 
}

// ----------------------------------------------------
// MODIFICATION PROJETS ET UTILISATEURS
// ----------------------------------------------------
function openProjectForm(pid){
  let p = project(pid);
  if(!p) return;
  document.getElementById('formTitle').textContent = 'Modifier le projet';
  
  let ownerOptions = db.users.map(u => `<option value="${u.id}" ${p.owner===u.id?'selected':''}>${u.name}</option>`).join('');
  let cdtOptions = db.cdts.map(c => `<option value="${c.id}" ${p.cdt===c.id?'selected':''}>${c.name}</option>`).join('');
  
  document.getElementById('formBody').innerHTML = `
    <div class="form-grid">
      <div class="mini-form-group full"><label class="mini-form-label">Nom</label><input id="fpName" class="mini-input" value="${p.name.replace(/"/g, '&quot;')}"></div>
      <div class="mini-form-group"><label class="mini-form-label">Secteur AOS</label><input id="fpSector" class="mini-input" value="${p.sector}"></div>
      <div class="mini-form-group"><label class="mini-form-label">CDT Usine</label><select id="fpCdt" class="mini-input">${cdtOptions}</select></div>
      <div class="mini-form-group"><label class="mini-form-label">Responsable</label><select id="fpOwner" class="mini-input">${ownerOptions}</select></div>
      <div class="mini-form-group full"><label class="mini-form-label">Priorité</label>
        <select id="fpPriority" class="mini-input"><option ${p.priority==='Haute'?'selected':''}>Haute</option><option ${p.priority==='Moyenne'?'selected':''}>Moyenne</option><option ${p.priority==='Basse'?'selected':''}>Basse</option></select>
      </div>
      <button class="btn btn-blue full" style="justify-content:center; margin-top:10px;" onclick="saveProjectForm('${pid}')">Enregistrer</button>
    </div>`;
  document.getElementById('formModal').classList.add('show');
}

function saveProjectForm(pid){
  let p = project(pid);
  if(!p) return;
  p.name = document.getElementById('fpName').value; 
  p.sector = document.getElementById('fpSector').value.toUpperCase(); 
  p.cdt = document.getElementById('fpCdt').value; 
  p.owner = document.getElementById('fpOwner').value; 
  p.priority = document.getElementById('fpPriority').value;
  closeForm(); 
  save('Projet modifié');
}

function openUserForm(uid){
  let u = db.users.find(x => x.id === uid);
  if(!u) return;
  document.getElementById('formTitle').textContent = 'Modifier utilisateur';
  document.getElementById('formBody').innerHTML = `
    <div class="form-grid">
      <div class="mini-form-group full"><label class="mini-form-label">Nom Complet</label><input id="fuName" class="mini-input" value="${u.name.replace(/"/g, '&quot;')}"></div>
      <div class="mini-form-group full"><label class="mini-form-label">Fonction</label><input id="fuRole" class="mini-input" value="${u.role.replace(/"/g, '&quot;')}"></div>
      <button class="btn btn-blue full" style="justify-content:center; margin-top:10px;" onclick="saveUserForm('${uid}')">Enregistrer</button>
    </div>`;
  document.getElementById('formModal').classList.add('show');
}

function saveUserForm(uid){
  let u = db.users.find(x => x.id === uid);
  if(!u) return;
  u.name = document.getElementById('fuName').value;
  u.role = document.getElementById('fuRole').value;
  closeForm(); 
  save('Utilisateur modifié');
}

function changePassword(){
  let n = prompt('Nouveau code responsable :');
  if(n) { db.password = n; save('Mot de passe modifié'); }
}

// ----------------------------------------------------
// OUTILS (NOTIFICATIONS, HISTORIQUE, EXPORT)
// ----------------------------------------------------
function alerts(){
  return [...activeActions().filter(a => effectiveStatus(a)==='late' || effectiveStatus(a)==='blocked'), ...activeWps().filter(w => effectiveStatus(w)==='blocked')];
}

function openNotifications(){
  let rows = alerts().map(x => {
    if(x.title){ let w = wp(x.wp); return `<div class="line"><span>${new Date().toISOString().slice(0,10)}</span><b>⚠ Action "${x.title}" en ${stTxt(effectiveStatus(x))} (WP ${w?.name})</b></div>`; }
    return `<div class="line"><span>${new Date().toISOString().slice(0,10)}</span><b>🔔 WP "${x.name}" bloqué</b></div>`;
  }).join('') || '<p>Aucune alerte.</p>';
  openSimple('Notifications', rows);
}

function openHistory(){
  let rows = db.history.map(h => `<div class="hist"><b>${h.date}</b> <br> <span style="font-weight:700; color:var(--airbus);">${h.object}</span> : ${h.old} → ${h.new} <br> <span style="font-size:10px; color:var(--muted); text-transform:uppercase;">Motif : ${h.reason}</span></div>`).join('') || '<p>Aucun historique.</p>';
  openSimple('Historique des modifications', rows);
}

function openGuide(){
  openSimple('Guide Utilisateur', `<div class="box"><h4>Accueil</h4><p>Vue globale.</p></div><div class="box"><h4>Roadmap Transverse Unique</h4><p>Croisez les filtres (CDT, Projets, Équipe) dans la fenêtre du Gantt pour afficher instantanément les données dont vous avez besoin sans changer de page.</p></div><div class="box"><h4>Modifications Intelligentes</h4><p>Le système vous demandera un motif <b>uniquement</b> si vous modifiez réellement une donnée clé. Appuyez sur Entrée pour valider directement sans écrire de motif.</p></div>`);
}

function openExport(){
  openSimple('Exporter / Imprimer', `<div class="actions"><button class="btn btn-blue" onclick="window.print()"><i class="fa-solid fa-print"></i> Imprimer en PDF</button><button class="btn btn-white" onclick="exportJson()"><i class="fa-solid fa-file-code"></i> Sauvegarde Data (JSON)</button><button class="btn btn-white" onclick="exportCsv()"><i class="fa-solid fa-file-csv"></i> Export Excel (CSV)</button></div>`);
}

function exportJson(){ download('aos-cockpit.json', JSON.stringify(db, null, 2), 'application/json'); }

function exportCsv(){
  let rows = [['Type','Nom','Projet/WP','Statut','Début','Fin']];
  activeWps().forEach(w => rows.push(['WP', w.name, project(w.project)?.name, stTxt(effectiveStatus(w)), w.start, w.end]));
  activeActions().forEach(a => rows.push(['Action', a.title, wp(a.wp)?.name, stTxt(effectiveStatus(a)), a.start, a.end]));
  download('aos-cockpit.csv', rows.map(r => r.map(v => `"${String(v||'').replace(/"/g,'""')}"`).join(';')).join('\n'), 'text/csv');
}

function download(name, content, type){
  let blob = new Blob([content], {type});
  let a = document.createElement('a'); 
  a.href = URL.createObjectURL(blob); 
  a.download = name; 
  a.click();
}

