                            <i id="icon-save-${side}" class="fa-solid fa-floppy-disk"></i> <span id="txt-save-${side}">Enregistrer</span>
                        </button>
                        <button type="button" onclick="toggleEditMode('${side}')" class="border border-slate-200 text-slate-600 hover:bg-slate-50 px-3 py-1.5 rounded-lg text-xs font-bold flex items-center gap-1.5 transition"><i class="fa-solid fa-xmark"></i> Annuler</button>
                    </div>
                </div>
                <div id="edit-scroll-${side}" data-preserve-scroll="edit-${side}" class="grid grid-cols-2 gap-4 flex-grow min-h-0 overflow-y-auto pr-1">
                    <div class="bg-slate-50 rounded-xl p-5 border border-slate-200 flex flex-col gap-4">
                        <div class="grid grid-cols-2 gap-3">
                            <div><label class="text-[10px] font-bold text-slate-400 uppercase">Nom de la Routine</label><input type="text" id="edit-daily-name-${side}" value="${draftData.daily.name.replace(/"/g, '&quot;')}" class="w-full border rounded-lg px-2 py-1.5 text-xs font-bold"></div>
                            <div><label class="text-[10px] font-bold text-slate-400 uppercase">Fréquence & Durée</label><input type="text" id="edit-daily-time-${side}" value="${draftData.daily.timeInfo.replace(/"/g, '&quot;')}" class="w-full border rounded-lg px-2 py-1.5 text-xs"></div>
                        </div>
                        <div><label class="text-[10px] font-bold text-slate-400 uppercase">Participants</label><input type="text" id="edit-daily-part-${side}" value="${draftData.daily.part.replace(/"/g, '&quot;')}" class="w-full border rounded-lg px-2 py-1.5 text-xs"></div>
                        <div class="flex flex-col"><span class="text-[10px] font-bold text-slate-400 uppercase mb-1">Points Traités</span><div class="bg-white rounded-lg p-3 border max-h-56 overflow-y-auto">${makeEditablePtsHTML('daily', draftData.daily.pts)}</div></div>
                        <div>${makeEditableActionsInlineHTML('daily', draftData.actions?.daily)}</div>
                        <div class="grid grid-cols-2 gap-3">
                            <div><label class="text-[10px] font-bold text-slate-400 uppercase">Préparation</label><input type="text" id="edit-daily-prep-${side}" value="${draftData.daily.prep.join(', ').replace(/"/g, '&quot;')}" class="w-full border rounded-lg px-2 py-1.5 text-xs"></div>
                            <div><label class="text-[10px] font-bold text-slate-400 uppercase">Routine</label><input type="text" id="edit-daily-routine-${side}" value="${draftData.daily.routine.join(', ').replace(/"/g, '&quot;')}" class="w-full border rounded-lg px-2 py-1.5 text-xs"></div>
                        </div>
                        <div class="flex flex-col gap-3">
                            <div class="p-2 border border-dashed border-slate-300 rounded-xl bg-white"><label class="text-[10px] font-bold text-emerald-600 uppercase">Points Positifs</label><textarea id="edit-daily-pos-${side}" class="w-full rounded px-1 py-1 text-xs h-16 resize-none outline-none focus:bg-slate-50">${draftData.daily.pos || ''}</textarea></div>
                            <div class="p-2 border border-dashed border-slate-300 rounded-xl bg-white"><label class="text-[10px] font-bold text-rose-500 uppercase">Irritants</label><textarea id="edit-daily-irr-${side}" class="w-full rounded px-1 py-1 text-xs h-16 resize-none outline-none focus:bg-slate-50">${draftData.daily.irr || ''}</textarea></div>
                        </div>
                        <div class="bg-blue-50 border border-blue-100 rounded-xl p-3"><label class="text-xs font-bold text-blue-700 mb-2 block">Maturité Daily (%)</label>${makeEditableMaturityInlineHTML(side, 'daily', draftData.maturity)}</div>
                    </div>
                    <div class="bg-slate-50 rounded-xl p-5 border border-slate-200 flex flex-col gap-4">
                        <div class="grid grid-cols-2 gap-3">
                            <div><label class="text-[10px] font-bold text-slate-400 uppercase">Nom de la Routine</label><input type="text" id="edit-weekly-name-${side}" value="${draftData.weekly.name.replace(/"/g, '&quot;')}" class="w-full border rounded-lg px-2 py-1.5 text-xs font-bold"></div>
                            <div><label class="text-[10px] font-bold text-slate-400 uppercase">Fréquence & Durée</label><input type="text" id="edit-weekly-time-${side}" value="${draftData.weekly.timeInfo.replace(/"/g, '&quot;')}" class="w-full border rounded-lg px-2 py-1.5 text-xs"></div>
                        </div>
                        <div><label class="text-[10px] font-bold text-slate-400 uppercase">Participants</label><input type="text" id="edit-weekly-part-${side}" value="${draftData.weekly.part.replace(/"/g, '&quot;')}" class="w-full border rounded-lg px-2 py-1.5 text-xs"></div>
                        <div class="flex flex-col"><span class="text-[10px] font-bold text-slate-400 uppercase mb-1">Points Traités</span><div class="bg-white rounded-lg p-3 border max-h-56 overflow-y-auto">${makeEditablePtsHTML('weekly', draftData.weekly.pts)}</div></div>
                        <div>${makeEditableActionsInlineHTML('weekly', draftData.actions?.weekly)}</div>
                        <div class="grid grid-cols-2 gap-3">
                            <div><label class="text-[10px] font-bold text-slate-400 uppercase">Préparation</label><input type="text" id="edit-weekly-prep-${side}" value="${draftData.weekly.prep.join(', ').replace(/"/g, '&quot;')}" class="w-full border rounded-lg px-2 py-1.5 text-xs"></div>
                            <div><label class="text-[10px] font-bold text-slate-400 uppercase">Routine</label><input type="text" id="edit-weekly-routine-${side}" value="${draftData.weekly.routine.join(', ').replace(/"/g, '&quot;')}" class="w-full border rounded-lg px-2 py-1.5 text-xs"></div>
                        </div>
                        <div class="flex flex-col gap-3">
                            <div class="p-2 border border-dashed border-slate-300 rounded-xl bg-white"><label class="text-[10px] font-bold text-emerald-600 uppercase">Points Positifs</label><textarea id="edit-weekly-pos-${side}" class="w-full rounded px-1 py-1 text-xs h-16 resize-none outline-none focus:bg-slate-50">${draftData.weekly.pos || ''}</textarea></div>
                            <div class="p-2 border border-dashed border-slate-300 rounded-xl bg-white"><label class="text-[10px] font-bold text-rose-500 uppercase">Irritants</label><textarea id="edit-weekly-irr-${side}" class="w-full rounded px-1 py-1 text-xs h-16 resize-none outline-none focus:bg-slate-50">${draftData.weekly.irr || ''}</textarea></div>
                        </div>
                        <div class="bg-emerald-50 border border-emerald-100 rounded-xl p-3"><label class="text-xs font-bold text-emerald-700 mb-2 block">Maturité Weekly (%)</label>${makeEditableMaturityInlineHTML(side, 'weekly', draftData.maturity)}</div>
                    </div>
                </div>
            `;
        }

        function togglePtStatusDraft(event, side, routineType, idx) {
            const draft = editDrafts[side];
            if (draft && draft[routineType]?.pts?.[idx]) {
                const pt = draft[routineType].pts[idx];
                pt.status = (pt.status === 'v') ? 'x' : 'v';
                const icon = event?.currentTarget?.querySelector('i');
                if (icon) icon.className = `fa-solid ${pt.status === 'v' ? 'fa-circle-check text-blue-500' : 'fa-circle-xmark text-rose-500'} text-lg`;
            }
        }
        function editPtTextDraft(side, routineType, idx, value) { const draft = editDrafts[side]; if(draft && draft[routineType]?.pts?.[idx]) draft[routineType].pts[idx].text = value; }
        function editActionFieldDraft(side, routineType, idx, field, value) { const draft = editDrafts[side]; if(draft && draft.actions?.[routineType]?.[idx]) draft.actions[routineType][idx][field] = value; }
       
        function editMaturityFieldDraft(side, routineType, criteriaKey, value) {
            const draft = editDrafts[side];
            if (draft && draft.maturity?.[routineType]) {
                if (window[`syncInputs_${side}`]) window[`syncInputs_${side}`]();
                draft.maturity[routineType][criteriaKey] = Math.max(0, Math.min(100, parseInt(value || '0', 10)));
            }
        }
       
        function editMaturityGradeDraft(side, value) { const draft = editDrafts[side]; if(draft) draft.maturityGrade = String(value || 'C').toUpperCase(); }

        function cycleActionStatusDraft(event, side, routineType, idx) {
            const draft = editDrafts[side];
            if (draft && draft.actions?.[routineType]?.[idx]) {
                if (window[`syncInputs_${side}`]) window[`syncInputs_${side}`]();
                const action = draft.actions[routineType][idx];
                action.status = nextActionStatus(action.status);
               
                const activeKey = (side === 'left') ? activeLeftKey : activeRightKey;
                const oldObj = db[activeKey];
                db[activeKey] = draft;
                enrichDatabase(db);
                db[activeKey] = oldObj;

                safeRenderDashboard();
            }
        }

        function saveGroupEdits(side, key) {
            const titleInput = document.getElementById(`edit-title-${side}`);
            const gradeInput = document.getElementById(`edit-group-grade-${side}`);

            if (titleInput && db[key]) db[key].title = titleInput.value;
            if (gradeInput && db[key]) db[key].maturityGrade = gradeInput.value;

            editModes[side] = false;
            editDrafts[side] = null;

            const payload = getSerializableDb();

            if (isAppsScriptRuntime()) {
                google.script.run.saveData(payload);
            } else {
                localStorage.setItem('ppc_sectors_db_custom_v6', JSON.stringify(payload));
            }

            renderSidebar();
            safeRenderDashboard();
        }

        function saveSectorEdits(side, key) {
            const draft = editDrafts[side]; if (!draft) return;
           
            const btn = document.getElementById(`btn-save-${side}`);
            const icon = document.getElementById(`icon-save-${side}`);
            const txt = document.getElementById(`txt-save-${side}`);
            if (btn && icon && txt) {
                btn.disabled = true;
                btn.className = "bg-slate-400 text-white px-3 py-1.5 rounded-lg text-xs font-bold flex items-center gap-1.5 cursor-not-allowed shadow-sm";
                icon.className = "fa-solid fa-spinner fa-spin";
                txt.textContent = "Enregistrement...";
            }

            const titleInput = document.getElementById(`edit-title-${side}`); if(titleInput) draft.title = titleInput.value;

            ['daily', 'weekly'].forEach(rType => {
                const name = document.getElementById(`edit-${rType}-name-${side}`);
                const time = document.getElementById(`edit-${rType}-time-${side}`);
                const part = document.getElementById(`edit-${rType}-part-${side}`);
                const prep = document.getElementById(`edit-${rType}-prep-${side}`);
                const rout = document.getElementById(`edit-${rType}-routine-${side}`);
                const irr = document.getElementById(`edit-${rType}-irr-${side}`);
                const pos = document.getElementById(`edit-${rType}-pos-${side}`);
                if(name) draft[rType].name = name.value;
                if(time) draft[rType].timeInfo = time.value;
                if(part) draft[rType].part = part.value;
                if(prep) draft[rType].prep = prep.value.split(',').map(s => s.trim()).filter(s => s !== "");
                if(rout) draft[rType].routine = rout.value.split(',').map(s => s.trim()).filter(s => s !== "");
                if(irr) draft[rType].irr = irr.value;
                if(pos) draft[rType].pos = pos.value;
            });

            db[key] = draft;
            enrichDatabase(db);
            const payload = getSerializableDb();
           
            if (isAppsScriptRuntime()) {
                google.script.run
                    .withSuccessHandler(() => {
                        editModes[side] = false;
                        editDrafts[side] = null;
                        renderSidebar();
                        safeRenderDashboard();
                    })
                    .withFailureHandler(e => {
                        alert('Erreur : ' + e.message);
                        safeRenderDashboard();
                    })
                    .saveData(payload);
            } else {
                localStorage.setItem('ppc_sectors_db_custom_v6', JSON.stringify(payload));
                editModes[side] = false; editDrafts[side] = null; renderSidebar(); safeRenderDashboard();
            }
        }

        function openAddSectorModal() { document.getElementById('new-sector-id').value = ''; document.getElementById('new-sector-title').value = ''; document.getElementById('add-sector-modal').classList.remove('hidden'); }
        function closeAddSectorModal() { document.getElementById('add-sector-modal').classList.add('hidden'); }

        submitNewSector = function() {
            const rawId = document.getElementById('new-sector-id').value.trim(); const rawTitle = document.getElementById('new-sector-title').value.trim(); if (!rawId) return;
            const key = rawId.toLowerCase().replace(/[^a-z0-9]/g, ''); if (db[key]) return;
            db[key] = { name: rawId, title: rawTitle || `Routines PPC – ${rawId} (2 VAC)`, daily: { name: "PPC Daily", timeInfo: "1 fois par vac, 30 min", part: "TL, Ordo", pts: [{ status: "v", text: "Suivre l'avance retard" }], prep: [], routine: [], irr: "", pos: "" }, weekly: { name: "PPC Weekly", timeInfo: "1 fois par semaine", part: "TL, RL", pts: [{ status: "v", text: "Performance" }], prep: [], routine: [], irr: "", pos: "" } };
           
            enrichDatabase(db);
            const payload = getSerializableDb();
            if (isAppsScriptRuntime()) google.script.run.saveData(payload);
           
            closeAddSectorModal(); activeLeftKey = key; initApp();
        }

        function confirmDeleteSector(key) { const item = db[key]; if (!item) return; document.getElementById('sector-to-delete').value = key; document.getElementById('delete-sector-name').innerText = item.name; document.getElementById('delete-confirm-modal').classList.remove('hidden'); }
        function closeDeleteConfirmModal() { document.getElementById('delete-confirm-modal').classList.add('hidden'); }

        function deleteSector() {
            const key = document.getElementById('sector-to-delete').value;
            if (db[key] && !db[key].isGroup) {
                delete db[key]; enrichDatabase(db); const rem = Object.keys(db);
                if (activeLeftKey === key) activeLeftKey = rem[0] || ""; if (activeRightKey === key) activeRightKey = rem[1] || rem[0] || "";
                const payload = getSerializableDb();
                if (isAppsScriptRuntime()) google.script.run.saveData(payload);
            }
            closeDeleteConfirmModal(); initApp();
        }

        function openResetConfirmModal() { document.getElementById('reset-confirm-modal').classList.remove('hidden'); }
        function closeResetConfirmModal() { document.getElementById('reset-confirm-modal').classList.add('hidden'); }

        function makeEditableMaturityInlineHTML(side, routineType, maturity) {
            const labels = routineType === 'daily' ? { avanceRetard: 'Avance / retard', aleas: 'Aléas', decision: 'Décision' } : { performance: 'Performance', paretoAleas: 'Pareto aléas', planAction: 'Plan d’action' };
            const obj = maturity?.[routineType] || {};
            return Object.keys(labels).map(k => `<div class="flex items-center gap-2 mb-1.5"><label class="text-[11px] font-semibold text-slate-600 w-32">${labels[k]}</label><input type="number" min="0" max="100" value="${obj[k] ?? 0}" oninput="editMaturityFieldDraft('${side}', '${routineType}', '${k}', this.value)" class="w-16 border rounded px-2 py-0.5 text-xs font-bold"><span class="text-xs text-slate-400">%</span></div>`).join('');
        }

        function escapeHtml(val) { return String(val ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
        function escapeAttr(val) { return escapeHtml(val).replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }
        function autoResizeTextarea(el) { if (!el) return; el.style.height = 'auto'; el.style.height = Math.max(42, el.scrollHeight) + 'px'; }
        function resizeAllActionTextareas() { document.querySelectorAll('.action-edit-action').forEach(autoResizeTextarea); }

        window.onload = function() { initApp(); };
    </script>
</body>
</html>
